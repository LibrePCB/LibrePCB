import { SideBarButton } from "./sidebarbutton.slint";
import { Globals, MainPage } from "./globals.slint";

export component SideBar inherits Rectangle {
    background: #353535;

    VerticalLayout {
        spacing: 0px;

        SideBarButton {
            icon: @image-url("img/home.svg");
            tooltip: "Home";
            checked: Globals.current-page == MainPage.home;
            clicked => {
                Globals.current-page = MainPage.home;
            }
        }

        SideBarButton {
            icon: @image-url("img/libraries.png");
            tooltip: "Libraries";
            status-background: #d4d400;
            status-color: black;
            status-text: (Globals.outdated-libraries > 0) ? Globals.outdated-libraries : "";
            checked: Globals.current-page == MainPage.libraries;
            clicked => {
                Globals.current-page = MainPage.libraries;
            }
        }

        SideBarButton {
            icon: @image-url("img/projects.png");
            tooltip: "Project";
            enabled: Globals.current-project.valid;
            checked: Globals.current-page == MainPage.project;
            clicked => {
                Globals.current-page = MainPage.project;
            }
        }

        SideBarButton {
            icon: @image-url("img/drc.svg");
            tooltip: "Design Rule Check";
            checked: Globals.current-page == MainPage.drc;
            enabled: Globals.current-project.valid;
            clicked => {
                Globals.current-page = MainPage.drc;
            }
        }

        SideBarButton {
            icon: @image-url("img/output-jobs.svg");
            tooltip: "Output Jobs";
            enabled: Globals.current-project.valid;
            checked: Globals.current-page == MainPage.output-jobs;
            clicked => {
                Globals.current-page = MainPage.output-jobs;
            }
        }

        SideBarButton {
            icon: @image-url("img/shopping-cart.svg");
            tooltip: "Order PCB";
            enabled: Globals.current-project.valid;
            checked: Globals.current-page == MainPage.order;
            clicked => {
                Globals.current-page = MainPage.order;
            }
        }

        SideBarButton {
            icon: @image-url("img/search.svg");
            tooltip: "Search";
            checked: Globals.current-page == MainPage.search;
            clicked => {
                Globals.current-page = MainPage.search;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        SideBarButton {
            icon: @image-url("img/help.svg");
            tooltip: "Help";
            checked: Globals.current-page == MainPage.help;
            clicked => {
                Globals.current-page = MainPage.help;
            }
        }

        SideBarButton {
            icon: @image-url("img/settings.svg");
            tooltip: "Preferences";
            checked: Globals.current-page == MainPage.preferences;
            clicked => {
                Globals.current-page = MainPage.preferences;
            }
        }
    }
}
