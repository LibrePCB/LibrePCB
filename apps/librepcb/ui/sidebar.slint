import { SideBarButton } from "./sidebarbutton.slint";
import { MainPage } from "./api/types.slint";
import { Data } from "./api/data.slint";
import { ActionId, ProjectData } from "./api/types.slint";
import { Backend } from "./api/backend.slint";

export component SideBar inherits Rectangle {
    property <ProjectData> project: Data.projects[Data.current-project-index];

    background: #353535;

    VerticalLayout {
        spacing: 0px;

        SideBarButton {
            icon: @image-url("img/home.svg");
            tooltip: @tr("Home");
            checked: Data.current-page == MainPage.home;

            clicked => {
                Data.current-page = MainPage.home;
            }
        }

        SideBarButton {
            icon: @image-url("img/libraries.png");
            tooltip: @tr("Libraries");
            status-background: #d4d400;
            status-color: black;
            status-text: (Data.outdated-libraries > 0) ? Data.outdated-libraries : "";
            checked: Data.current-page == MainPage.libraries;

            clicked => {
                Data.current-page = MainPage.libraries;
            }
        }

        SideBarButton {
            icon: @image-url("img/projects.png");
            tooltip: @tr("Project");
            enabled: project.valid;
            checked: Data.current-page == MainPage.project;

            clicked => {
                Data.current-page = MainPage.project;
            }
        }

        SideBarButton {
            icon: @image-url("img/drc.svg");
            tooltip: @tr("Design Rule Check");
            enabled: project.valid;
            checked: Data.current-page == MainPage.drc;

            clicked => {
                Data.current-page = MainPage.drc;
            }
        }

        SideBarButton {
            icon: @image-url("img/output-jobs.svg");
            tooltip: @tr("Output Jobs");
            enabled: project.valid;

            clicked => {
                Backend.action-triggered(ActionId.project-open-output-jobs, Data.current-project-index);
            }
        }

        SideBarButton {
            icon: @image-url("img/shopping-cart.svg");
            tooltip: @tr("Order PCB");
            enabled: project.valid;
            checked: Data.current-page == MainPage.order;

            clicked => {
                Data.current-page = MainPage.order;
            }
        }

        SideBarButton {
            icon: @image-url("img/search.svg");
            tooltip: @tr("Search");
            checked: Data.current-page == MainPage.search;

            clicked => {
                Data.current-page = MainPage.search;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        SideBarButton {
            icon: @image-url("img/settings.svg");
            tooltip: @tr("Preferences");
            checked: false;

            clicked => {
                Backend.action-triggered(ActionId.open-workspace-settings, -1);
            }
        }

        SideBarButton {
            icon: @image-url("img/help.svg");
            tooltip: @tr("Help / About");
            checked: Data.current-page == MainPage.help;

            clicked => {
                Data.current-page = MainPage.help;
            }
        }
    }
}
