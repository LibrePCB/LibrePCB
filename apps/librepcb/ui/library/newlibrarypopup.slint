import { Button, LineEdit, CheckBox } from "std-widgets.slint";
import { LineEdit } from "../lineedit.slint";

global Globals {
    pure callback get-name() -> string;
    pure callback name-edited(string) -> string;

    pure callback get-description() -> string;
    pure callback description-edited(string) -> string;

    pure callback get-author() -> string;
    pure callback get-author-fallback() -> string;
    pure callback author-edited(value: string, fallback: string) -> string;

    pure callback get-version() -> string;
    pure callback get-version-fallback() -> string;
    pure callback version-edited(value: string, fallback: string) -> string;

    pure callback get-url() -> string;
    pure callback url-edited(string) -> string;

    pure callback get-cc0() -> bool;
    pure callback cc0-toggled(bool);

    pure callback get-directory() -> string;
    pure callback get-directory-fallback(name: string) -> string;
    pure callback directory-edited(value: string, fallback: string) -> string;

    pure callback create() -> string;

    in-out property <bool> valid: false;
}

export { Globals as CreateLocalLibraryGlobals }

export component NewLibraryPopup inherits PopupWindow {
    close-policy: PopupClosePolicy.close-on-click-outside;

    Rectangle {
        background: #202020;

        GridLayout {
            height: self.preferred-height;
            padding: 10px;
            spacing: 5px;

            Row {
                Text {
                    colspan: 2;
                    height: self.preferred-height + 10px;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    text: @tr("Create a new local library in the currently opened workspace");
                }
            }

            Row {
                Text {
                    colspan: 2;
                    wrap: TextWrap.word-wrap;
                    text: @tr("To import KiCad or Eagle libraries, create a new library called e.g. 'KiCad Import' or 'Eagle Import'. Then open the new library and start the import wizard via 'File -> Import'.");
                }
            }

            Row {
                Rectangle {
                    colspan: 2;
                    height: 1px;
                    background: gray;
                }
            }

            Row {
                Text {
                    text: @tr("Name:");
                    vertical-alignment: center;
                }

                le-name := LineEdit {
                    placeholder-text: @tr("My Library");

                    init => {
                        self.text = Globals.get-name();
                    }

                    input-handler(t) => {
                        Globals.name-edited(t);
                    }
                }
            }

            Row {
                Text {
                    text: @tr("Description:");
                    vertical-alignment: center;
                }

                le-description := LineEdit {
                    init => {
                        self.text = Globals.get-description();
                    }

                    input-handler(t) => {
                        Globals.description-edited(t);
                    }
                }
            }

            Row {
                Text {
                    text: @tr("Author:");
                    vertical-alignment: center;
                }

                le-author := LineEdit {
                    placeholder-text: Globals.get-author-fallback();

                    init => {
                        self.text = Globals.get-author();
                    }

                    input-handler(t) => {
                        Globals.author-edited(t, self.placeholder-text);
                    }
                }
            }

            Row {
                Text {
                    text: @tr("Version:");
                    vertical-alignment: center;
                }

                le-version := LineEdit {
                    placeholder-text: Globals.get-version-fallback();

                    init => {
                        self.text = Globals.get-version();
                    }

                    input-handler(t) => {
                        Globals.version-edited(t, self.placeholder-text);
                    }
                }
            }

            Row {
                Text {
                    text: @tr("URL:");
                    vertical-alignment: center;
                }

                le-url := LineEdit {
                    placeholder-text: @tr("e.g. URL to the Git repository (optional)");

                    init => {
                        self.text = Globals.get-url();
                    }

                    input-handler(t) => {
                        Globals.url-edited(t);
                    }
                }
            }

            Row {
                Text {
                    text: @tr("License:");
                    vertical-alignment: center;
                }

                cbx-cc0 := CheckBox {
                    horizontal-stretch: 1;
                    checked: Globals.get-cc0();
                    text: @tr("Put library under the Public Domain License CC0-1.0\n(mandatory to publish it on librepcb.org)");

                    init => {
                        self.checked = Globals.get-cc0();
                    }
                }
            }

            Row {
                Text {
                    text: @tr("Directory:");
                    vertical-alignment: center;
                }

                le-directory := LineEdit {
                    placeholder-text: Globals.get-directory-fallback(le-name.text);

                    init => {
                        self.text = Globals.get-directory();
                    }

                    input-handler(t) => {
                        Globals.directory-edited(t, self.placeholder-text);
                    }
                }
            }

            Row {
                HorizontalLayout {
                    colspan: 2;
                    alignment: end;

                    Button {
                        text: @tr("Cancel");

                        clicked => {
                            root.close();
                        }
                    }

                    Button {
                        primary: true;
                        enabled: Globals.valid;
                        text: @tr("Create Library");

                        clicked => {
                            ti-error-msg.text = Globals.create();
                            if ti-error-msg.text == "" {
                                //root.close();
                            }
                        }
                    }
                }
            }

            Row {
                ti-error-msg := TextInput {
                    colspan: 2;
                    height: (self.text != "") ? self.preferred-height : 0;
                    color: red;
                    read-only: true;
                    wrap: word-wrap;
                }
            }
        }
    }
}
