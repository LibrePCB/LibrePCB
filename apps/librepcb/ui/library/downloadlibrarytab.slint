import { Button, LineEdit, CheckBox } from "std-widgets.slint";
import { LineEdit } from "../lineedit.slint";
import { Globals, WindowSection, DownloadLibraryTabData } from "../globals.slint";

export component DownloadLibraryTab inherits Rectangle {
    in property <int> section-index;
    in-out property <WindowSection> section;
    property <[DownloadLibraryTabData]> tabs: section.download-library-tabs;

    GridLayout {
        padding: 10px;
        spacing: 5px;

        Row {
            Text {
                colspan: 2;
                height: self.preferred-height + 10px;
                font-size: 14px;
                font-weight: 600;
                wrap: TextWrap.word-wrap;
                text: @tr("Download & install a library by URL");
            }
        }

        Row {
            Text {
                colspan: 2;
                wrap: TextWrap.word-wrap;
                text: @tr("Please note that this way of installing libraries is not recommended as there's no way to keep them updated in a simple way. For libraries available in the library manager, please install them with the library manager instead as there's an update mechanism provided.");
            }
        }

        Row {
            Rectangle {
                colspan: 2;
                height: 1px;
                background: gray;
            }
        }

        Row {
            Text {
                text: @tr("URL:");
                vertical-alignment: center;
            }

            le-url := LineEdit {
                text: tabs[section.current-tab-index].url;
                placeholder-text: @tr("URL to library (e.g. *.zip)");
                validation-error: tabs[section.current-tab-index].url-error;

                changed text => {
                    tabs[section.current-tab-index].url = self.text;
                }
            }
        }

        Row {
            Text {
                text: @tr("Directory:");
                vertical-alignment: center;
            }

            le-directory := LineEdit {
                text: tabs[section.current-tab-index].directory;
                placeholder-text: tabs[section.current-tab-index].directory-default;
                validation-error: tabs[section.current-tab-index].directory-error;

                changed text => {
                    tabs[section.current-tab-index].directory = self.text;
                }
            }
        }

        Row {
            Rectangle { }

            HorizontalLayout {
                horizontal-stretch: 1;
                alignment: start;

                Button {
                    primary: true;
                    enabled: tabs[section.current-tab-index].valid;
                    text: @tr("Download Library");

                    clicked => {
                        if (Globals.create-library(section-index)) {
                            Globals.tab-close-clicked(section-index, section.current-tab-index);
                        }
                    }
                }

                Button {
                    text: @tr("Cancel");

                    clicked => {
                        Globals.tab-close-clicked(section-index, section.current-tab-index);
                    }
                }
            }
        }

        Row {
            Rectangle { }

            TextInput {
                horizontal-stretch: 1;
                height: (self.text != "") ? self.preferred-height : 0;
                color: red;
                read-only: true;
                wrap: word-wrap;
                text: tabs[section.current-tab-index].download-error;
            }
        }

        Row {
            Rectangle {
                vertical-stretch: 1;
            }
        }
    }
}
