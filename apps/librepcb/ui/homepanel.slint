import { ListView } from "std-widgets.slint";
import { PanelHeader, PanelHeaderButton } from "./common/panelheader.slint";
import { FolderTreeItemData, QuickAccessItemData } from "./api/types.slint";
import { Backend } from "./api/backend.slint";
import { Data } from "./api/data.slint";
import { ListViewItemButton } from "./common/listviewitembutton.slint";

component QuickAccessList inherits ListView {
    property <int> current-index: -1;
    property <length> item-height: 20px;
    in-out property <[QuickAccessItemData]> model: Data.quick-access-items;

    preferred-height: model.length * item-height;

    for item[index] in model: Rectangle {
        width: parent.width;
        height: item-height;
        background: (current-index == index) ? #454545 : (ta.has-hover ? #383838 : transparent);

        ta := TouchArea {
            HorizontalLayout {
                spacing: 5px;
                padding-left: 5px;
                padding-right: 5px;

                Image {
                    y: 1px;
                    width: parent.height - 2px;
                    height: parent.height - 2px;
                    source: @image-url("img/library.png");
                }

                Text {
                    horizontal-stretch: 1;
                    color: #dddddd;
                    font-size: 14px;
                    font-weight: 400;
                    overflow: TextOverflow.elide;
                    text: item.name;
                }

                if item.pinned || ta.has-hover || (current-index == index): ListViewItemButton {
                    icon: item.pinned ? @image-url("img/pin-angle-fill.svg") : @image-url("img/pin-angle.svg");
                    tooltip: item.pinned ? @tr("Unpin") : @tr("Pin");

                    clicked => {
                        item.pinned = !item.pinned;
                    }
                }
            }

            clicked => {
                current-index = index;
                Data.current-project-preview-path = item.path;
            }

            double-clicked => {
                Backend.project-item-doubleclicked(item.path);
            }
        }
    }
}

component FolderTree inherits ListView {
    property <int> current-index: -1;
    property <length> item-height: 20px;
    in-out property <[FolderTreeItemData]> model;

    preferred-height: model.length * item-height;

    callback item-selected(string);

    for item[index] in model: Rectangle {
        width: parent.width;
        height: item-height;
        background: (current-index == index) ? #454545 : (ta.has-hover ? #383838 : transparent);

        HorizontalLayout {
            spacing: 5px;
            padding-left: 5px + item.level * i-icon.width;

            if (item.is-folder) || (item.level > 0): Text {
                color: #dddddd;
                font-size: 14px;
                font-weight: 700;
                overflow: TextOverflow.elide;
                visible: item.is-folder;
                text: "▸";
            }

            i-icon := Image {
                y: 1px;
                width: parent.height - 2px;
                height: parent.height - 2px;
                source: item.icon;
            }

            Text {
                horizontal-stretch: 1;
                color: #dddddd;
                font-size: 14px;
                font-weight: 400;
                overflow: TextOverflow.elide;
                text: item.name;
            }
        }

        ta := TouchArea {
            clicked => {
                current-index = index;
                item-selected(item.path);
            }

            double-clicked => {
                Backend.project-item-doubleclicked(item.path);
            }
        }
    }
}

export component HomePanel inherits Rectangle {
    background: #2a2a2a;

    VerticalLayout {
        if Data.quick-access-items.length > 0: PanelHeader {
            title: @tr("QUICK ACCESS");

            PanelHeaderButton {
                icon: @image-url("img/file-circle-plus.svg");
            }

            PanelHeaderButton {
                icon: @image-url("img/folder-open.svg");
            }
        }

        if Data.quick-access-items.length > 0: QuickAccessList {
            vertical-stretch: 0;
        }

        if Data.quick-access-items.length > 0: Rectangle {
            height: 15px;
        }

        PanelHeader {
            title: @tr("WORKSPACE");
        }

        FolderTree {
            vertical-stretch: 2;
            model: Data.workspace-folder;

            item-selected(path) => {
                Data.current-project-preview-path = path;
            }
        }

        Rectangle { }
    }
}
