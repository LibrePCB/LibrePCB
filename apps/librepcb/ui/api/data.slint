    in property <[QuickAccessItemData]> quick-access-items: [
        {
            name: "project-1.lpp",
            path: "/path/to/project-1.lpp",
            pinned: false,
        },
        {
            name: "project-2.lpp",
            path: "/path/to/project-2.lpp",
            pinned: false,
        },
        {
            name: "project-3.lpp",
            path: "/path/to/project-3.lpp",
            pinned: true,
