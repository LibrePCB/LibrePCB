    in-out property <int> current-section-index: 0;

    // Constant data
    out property <[LengthUnit]> all-length-units: [
        LengthUnit.millimeters,
        LengthUnit.micrometers,
        LengthUnit.nanometers,
        LengthUnit.inches,
        LengthUnit.mils,
    ];

    // Auto-calculated data
    in-out property <ProjectData> current-project: projects[current-project-index];
    in-out property <WindowSectionData> current-section: sections[current-section-index];
    in-out property <TabData> current-tab: current-section.tabs[current-section.current-tab-index];
    out property <bool> current-tab-is-2d: (current-tab.type == TabType.schematic) || (current-tab.type == TabType.board-2d);
    out property <bool> current-tab-is-2d-or-3d: (current-tab.type == TabType.schematic) || (current-tab.type == TabType.board-2d) || (current-tab.type == TabType.board-3d);
    in-out property <SchematicTabData> current-schematic-tab: current-section.schematic-tabs[current-section.current-tab-index];
    in-out property <Board2dTabData> current-board-2d-tab: current-section.board-2d-tabs[current-section.current-tab-index];
    out property <GridStyle> current-grid-style: (current-tab.type == TabType.schematic) ? current-schematic-tab.grid-style : current-board-2d-tab.grid-style;
    out property <string> current-grid-interval: (current-tab.type == TabType.schematic) ? current-schematic-tab.grid-interval : current-board-2d-tab.grid-interval;
    out property <LengthUnit> current-unit: (current-tab.type == TabType.schematic) ? current-schematic-tab.unit : current-board-2d-tab.unit;

    public function set-current-grid-style(gs: GridStyle) {
        if (current-tab.type == TabType.schematic) {
            current-section.schematic-tabs[current-section.current-tab-index].grid-style = gs;
        } else if (current-tab.type == TabType.board-2d) {
            current-section.board-2d-tabs[current-section.current-tab-index].grid-style = gs;
        } else {
            debug("Unhandled case in set-current-grid-style().");
        }
    }

    public function set-current-unit(u: LengthUnit) {
        if (current-tab.type == TabType.schematic) {
            current-section.schematic-tabs[current-section.current-tab-index].unit = u;
        } else if (current-tab.type == TabType.board-2d) {
            current-section.board-2d-tabs[current-section.current-tab-index].unit = u;
        } else {
            debug("Unhandled case in set-current-unit().");
        }
    }

    pure public function get-unit-short-str(u: LengthUnit) -> string {
        if (u == LengthUnit.millimeters) {
            return "mm";
        } else if (u == LengthUnit.micrometers) {
            return "μm";
        } else if (u == LengthUnit.nanometers) {
            return "nm";
        } else if (u == LengthUnit.inches) {
            return "inch";
        } else if (u == LengthUnit.mils) {
            return "mils";
        } else {
            debug("Unhandled case in get-unit-short-str().");
            return "";
        }
    }

    pure public function get-icon-for-notification-type(nt: NotificationType) -> image {
        if (nt == NotificationType.tip) {
            return @image-url("../img/lightbulb.svg");
        } else if (nt == NotificationType.info) {
            return @image-url("../img/circle-info.svg");
        } else if (nt == NotificationType.warning) {
            return @image-url("../img/triangle-exclamation.svg");
        } else if (nt == NotificationType.critical) {
            return @image-url("../img/circle-xmark.svg");
        } else if (nt == NotificationType.progress) {
            return @image-url("../img/refresh.svg");
        } else {
            debug("Unhandled case in get-icon-for-notification-type().");
            return @image-url("");
        }
    }

    pure public function get-color-for-notification-type(nt: NotificationType) -> color {
        if (nt == NotificationType.tip) {
            return #00e1ff;
        } else if (nt == NotificationType.info) {
            return white;
        } else if (nt == NotificationType.warning) {
            return yellow;
        } else if (nt == NotificationType.critical) {
            return red;
        } else if (nt == NotificationType.progress) {
            return white;
        } else {
            debug("Unhandled case in get-color-for-notification-type().");
            return white;
        }
    }

    public function section-clicked(index: int) {
        if (current-section-index != index) {
            current-section-index = index;
            if ((current-tab.project-index >= 0) && (current-tab.project-index < Data.projects.length)) {
                current-project-index = current-tab.project-index;
            }
        }
    }

    pure public function get-rule-check-title-for-tab-type(type: TabType) -> string {
        if (type == TabType.schematic) {
            return @tr("Electrical Rule Check (ERC)");
        } else if (type == TabType.board-2d) {
            return @tr("Design Rule Check (DRC)");
        } else {
            return "";
        }
    }
}
