import { Backend } from "./api/backend.slint";
import { Data } from "./api/data.slint";

export component EmptyTab inherits Rectangle {
    in property <int> section-index;

    fs := FocusScope {
        enabled: false;
    }

    i-background := Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(root.width * 0.25, 200px);
        height: self.width;
        source: @image-url("img/librepcb-monochrome.svg");
        colorize: #404040;
    }

    Text {
        y: (i-background.y - self.height) / 2;
        width: 90%;
        color: gray;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-size: 30px;
        wrap: word-wrap;
        text: @tr("Open a library, schematic or board.");
    }

    TouchArea {
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                Data.section-clicked(section-index);
                if (!fs.has-focus) {
                    fs.focus();
                }
            }
            return EventResult.accept;
        }
    }
}
