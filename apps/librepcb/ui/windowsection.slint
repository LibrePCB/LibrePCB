import { Globals, Tab, TabType, WindowSection } from "./globals.slint";
import { SceneButton } from "./scenebutton.slint";

component TabItem inherits Rectangle {
    in property <Tab> tab;
    in property <int> index;
    in property <bool> is-current-section: false;
    in property <bool> is-current-tab: false;

    callback clicked <=> ta-tab.clicked;
    callback close-clicked <=> ta-tab-close.clicked;

    background: is-current-tab ? #505050 : (ta-tab.has-hover ? #404040 : #303030);

    ta-tab := TouchArea { }

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 2px;
        spacing: 3px;

        Image {
            width: 16px;
            source: (tab.type == TabType.schematic) ? @image-url("img/image.svg") : @image-url("img/projects.png");
        }

        t-tab := Text {
            vertical-alignment: TextVerticalAlignment.center;
            color: is-current-tab ? white : #a0a0a0;
            text: tab.title;
        }

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: i-tab-close.width;
            height: i-tab-close.height;
            background: ta-tab-close.has-hover ? #454545 : transparent;
            border-radius: 3px;

            i-tab-close := Image {
                source: @image-url("img/close.svg");
                colorize: t-tab.color;
            }

            ta-tab-close := TouchArea { }
        }
    }

    if (is-current-section) && (is-current-tab): Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 1px;
        background: #29d682;
    }
}

component TabBar inherits Rectangle {
    in-out property <WindowSection> section;
    property <bool> is-current-section: (section.index == Globals.current-section);

    x: 0;
    y: 0;
    height: 30px;
    background: #353535;

    Rectangle {
        x: 0;
        width: controls.x;
        clip: true;

        HorizontalLayout {
            alignment: LayoutAlignment.start;
            width: 100%;

            for tab[index] in section.tabs: TabItem {
                tab: tab;
                index: index;
                is-current-section: is-current-section;
                is-current-tab: (index == section.tab-index);

                clicked => {
                    if Globals.preview-mode {
                        section.tab-index = index;
                    } else {
                        Globals.tab-clicked(section.index, index);
                    }
                }

                close-clicked => {
                    Globals.tab-close-clicked(section.index, index);
                }
            }
        }
    }

    controls := HorizontalLayout {
        x: parent.width - self.width;
        width: self.preferred-width;
        padding: 3px;

        Rectangle {
            width: self.height;
            background: ta-section-split.has-hover ? #454545 : transparent;
            border-radius: 3px;

            Image {
                height: parent.height - 10px;
                source: @image-url("img/layout-split.svg");
                colorize: #d3d3d3;
            }

            ta-section-split := TouchArea {
                clicked => {
                    Globals.section-split-clicked(section.index);
                }
            }
        }

        if section.tabs.length == 0: Rectangle {
            width: self.height;
            background: ta-section-close.has-hover ? #454545 : transparent;
            border-radius: 3px;

            Image {
                height: parent.height - 4px;
                source: @image-url("img/close.svg");
                colorize: #d3d3d3;
            }

            ta-section-close := TouchArea {
                clicked => {
                    Globals.section-close-clicked(section.index);
                }
            }
        }
    }
}

export component WindowSection inherits Rectangle {
    in-out property <WindowSection> section;

    tab-bar := TabBar {
        section: section;
    }

    scene := Image {
        x: 0;
        y: tab-bar.height;
        width: 100%;
        height: parent.height - self.y;
        image-fit: ImageFit.preserve;
        image-rendering: ImageRendering.pixelated;
        source: Globals.render-scene(section.index, section.tab-index, scene.width, scene.height, section.frame);

        TouchArea {
            pointer-event(e) => {
                return Globals.scene-pointer-event(section.index, self.mouse-x, self.mouse-y, scene.width, scene.height, e);
            }
            scroll-event(e) => {
                return Globals.scene-scrolled(section.index, self.mouse-x, self.mouse-y, scene.width, scene.height, e);
            }
        }

        VerticalLayout {
            x: parent.width - self.preferred-width - 10px;
            y: 10px;
            width: self.preferred-width;
            spacing: 5px;

            SceneButton {
                image: @image-url("img/zoom-fit.svg");
                colorize: section.tabs[section.tab-index].overlay-color;
                clicked => {
                    Globals.scene-zoom-fit-clicked(section.index, scene.width, scene.height);
                }
            }

            SceneButton {
                image: @image-url("img/zoom-in.svg");
                colorize: section.tabs[section.tab-index].overlay-color;
                clicked => {
                    Globals.scene-zoom-in-clicked(section.index, scene.width, scene.height);
                }
            }

            SceneButton {
                image: @image-url("img/zoom-out.svg");
                colorize: section.tabs[section.tab-index].overlay-color;
                clicked => {
                    Globals.scene-zoom-out-clicked(section.index, scene.width, scene.height);
                }
            }

            if section.tabs[section.tab-index].type == TabType.board-2d: SceneButton {
                text: "3D";
                colorize: section.tabs[section.tab-index].overlay-color;
                clicked => {
                    Globals.board-3d-clicked(section.index, section.tab-index);
                }
            }
        }
    }
}
