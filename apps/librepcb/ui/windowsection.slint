import { Tab, TabType, WindowSection, ActionId } from "./types.slint";
import { EmptyTab } from "./emptytab.slint";
import { SchematicTab } from "./project/schematic/schematictab.slint";
import { Board2dTab } from "./project/board2dtab.slint";
import { Board3dTab } from "./project/board3dtab.slint";
import { CreateLibraryTab } from "./library/createlibrarytab.slint";
import { DownloadLibraryTab } from "./library/downloadlibrarytab.slint";
import { Backend } from "./backend.slint";
import { Data } from "./data.slint";

component TabItem inherits Rectangle {
    in property <Tab> tab;
    in property <int> index;
    in property <bool> is-current-section: false;
    in property <bool> is-current-tab: false;

    callback clicked <=> ta-tab.clicked;
    callback close-clicked <=> ta-tab-close.clicked;

    background: is-current-tab ? #505050 : (ta-tab.has-hover ? #404040 : #303030);

    ta-tab := TouchArea { }

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 2px;
        spacing: 3px;

        Image {
            width: 16px;
            source: (tab.type == TabType.schematic) ? @image-url("img/image.svg") : @image-url("img/projects.png");
        }

        t-tab := Text {
            vertical-alignment: TextVerticalAlignment.center;
            color: is-current-tab ? white : #a0a0a0;
            text: tab.title;
        }

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: i-tab-close.width;
            height: i-tab-close.height;
            background: ta-tab-close.has-hover ? #454545 : transparent;
            border-radius: 3px;

            i-tab-close := Image {
                source: @image-url("img/close.svg");
                colorize: t-tab.color;
            }

            ta-tab-close := TouchArea { }
        }
    }

    if (is-current-section) && (is-current-tab): Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 1px;
        background: #29d682;
    }
}

export component WindowSection inherits Rectangle {
    in-out property <int> section-index;
    in-out property <WindowSection> section;
    property <bool> is-current-section: (section-index == Data.current-section-index);
    property <bool> tab-open: (section.current-tab-index >= 0) && (section.current-tab-index < section.tabs.length);
    property <TabType> tab-type: section.tabs[section.current-tab-index].type;

    tab-bar := Rectangle {
        x: 0;
        y: 0;
        height: 30px;
        background: #353535;

        Rectangle {
            x: 0;
            width: controls.x;
            clip: true;

            HorizontalLayout {
                alignment: LayoutAlignment.start;
                width: 100%;

                for tab[index] in section.tabs: TabItem {
                    tab: tab;
                    index: index;
                    is-current-section: is-current-section;
                    is-current-tab: (index == section.current-tab-index);

                    clicked => {
                        if Data.preview-mode {
                            section.current-tab-index = index;
                        } else {
                            Backend.tab-clicked(section-index, index);
                        }
                    }

                    close-clicked => {
                        Backend.tab-close-clicked(section-index, index);
                    }
                }
            }
        }

        controls := HorizontalLayout {
            x: parent.width - self.width;
            width: self.preferred-width;
            padding: 3px;

            Rectangle {
                width: self.height;
                background: ta-section-split.has-hover ? #454545 : transparent;
                border-radius: 3px;

                Image {
                    height: parent.height - 10px;
                    source: @image-url("img/layout-split.svg");
                    colorize: #d3d3d3;
                }

                ta-section-split := TouchArea {
                    clicked => {
                        Backend.action-triggered(ActionId.section-split, section-index);
                    }
                }
            }

            if (Data.sections.length > 1) && (section.tabs.length == 0): Rectangle {
                width: self.height;
                background: ta-section-close.has-hover ? #454545 : transparent;
                border-radius: 3px;

                Image {
                    height: parent.height - 4px;
                    source: @image-url("img/close.svg");
                    colorize: #d3d3d3;
                }

                ta-section-close := TouchArea {
                    clicked => {
                        Backend.action-triggered(ActionId.section-close, section-index);
                    }
                }
            }
        }
    }

    Rectangle {
        x: 0;
        y: tab-bar.height;
        width: root.width;
        height: parent.height - self.y;

        if (!tab-open): EmptyTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
        }

        if (tab-open) && (tab-type == TabType.create-library): CreateLibraryTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
            section: section;
        }

        if (tab-open) && (tab-type == TabType.download-library): DownloadLibraryTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
            section: section;
        }

        if (tab-open) && (tab-type == TabType.schematic): SchematicTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
            section: section;
        }

        if (tab-open) && (tab-type == TabType.board-2d): Board2dTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
            section: section;
        }

        if (tab-open) && (tab-type == TabType.board-3d): Board3dTab {
            width: 100%;
            height: 100%;
            section-index: section-index;
            section: section;
        }
    }
}
