import { Globals, Tab, TabType, WindowSection } from "./globals.slint";
import { EmptyTab } from "./emptytab.slint";
import { SchematicTab } from "./project/schematictab.slint";
import { Board2dTab } from "./project/board2dtab.slint";
import { Board3dTab } from "./project/board3dtab.slint";
import { CreateLibraryTab } from "./library/createlibrarytab.slint";

component TabItem inherits Rectangle {
    in property <Tab> tab;
    in property <int> index;
    in property <bool> is-current-section: false;
    in property <bool> is-current-tab: false;

    callback clicked <=> ta-tab.clicked;
    callback close-clicked <=> ta-tab-close.clicked;

    background: is-current-tab ? #505050 : (ta-tab.has-hover ? #404040 : #303030);

    ta-tab := TouchArea { }

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 2px;
        spacing: 3px;

        Image {
            width: 16px;
            source: (tab.type == TabType.schematic) ? @image-url("img/image.svg") : @image-url("img/projects.png");
        }

        t-tab := Text {
            vertical-alignment: TextVerticalAlignment.center;
            color: is-current-tab ? white : #a0a0a0;
            text: tab.title;
        }

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: i-tab-close.width;
            height: i-tab-close.height;
            background: ta-tab-close.has-hover ? #454545 : transparent;
            border-radius: 3px;

            i-tab-close := Image {
                source: @image-url("img/close.svg");
                colorize: t-tab.color;
            }

            ta-tab-close := TouchArea { }
        }
    }

    if (is-current-section) && (is-current-tab): Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 1px;
        background: #29d682;
    }
}

export component WindowSection inherits Rectangle {
    in-out property <WindowSection> section;
    property <bool> is-current-section: (section.id == Globals.current-section-id);
    property <bool> tab-open: (section.tab-index >= 0) && (section.tab-index < section.tabs.length);
    property <TabType> tab-type: section.tabs[section.tab-index].type;

    tab-bar := Rectangle {
        x: 0;
        y: 0;
        height: 30px;
        background: #353535;

        Rectangle {
            x: 0;
            width: controls.x;
            clip: true;

            HorizontalLayout {
                alignment: LayoutAlignment.start;
                width: 100%;

                for tab[index] in section.tabs: TabItem {
                    tab: tab;
                    index: index;
                    is-current-section: is-current-section;
                    is-current-tab: (index == section.tab-index);

                    clicked => {
                        if Globals.preview-mode {
                            section.tab-index = index;
                        } else {
                            Globals.tab-clicked(section.id, index);
                        }
                    }

                    close-clicked => {
                        Globals.tab-close-clicked(section.id, index);
                    }
                }
            }
        }

        controls := HorizontalLayout {
            x: parent.width - self.width;
            width: self.preferred-width;
            padding: 3px;

            Rectangle {
                width: self.height;
                background: ta-section-split.has-hover ? #454545 : transparent;
                border-radius: 3px;

                Image {
                    height: parent.height - 10px;
                    source: @image-url("img/layout-split.svg");
                    colorize: #d3d3d3;
                }

                ta-section-split := TouchArea {
                    clicked => {
                        Globals.section-split-clicked(section.id);
                    }
                }
            }

            if (Globals.sections.length > 1) && (section.tabs.length == 0): Rectangle {
                width: self.height;
                background: ta-section-close.has-hover ? #454545 : transparent;
                border-radius: 3px;

                Image {
                    height: parent.height - 4px;
                    source: @image-url("img/close.svg");
                    colorize: #d3d3d3;
                }

                ta-section-close := TouchArea {
                    clicked => {
                        Globals.section-close-clicked(section.id);
                    }
                }
            }
        }
    }

    if (!tab-open): EmptyTab {
        x: 0;
        y: tab-bar.height;
        width: root.width;
        height: parent.height - self.y;
        section-id: section.id;
    }

    if (tab-open) && (tab-type == TabType.create-library): CreateLibraryTab {
        x: 0;
        y: tab-bar.height;
        width: parent.width;
        height: parent.height - self.y;
        section-id: section.id;
        tab-id: section.tabs[section.tab-index].id;
        data-model: Globals.create-library-tabs;
    }

    if (tab-open) && (tab-type == TabType.schematic): SchematicTab {
        x: 0;
        y: tab-bar.height;
        width: 100%;
        height: parent.height - self.y;
        section-id: section.id;
        tab-index: section.tab-index;
        tab: section.tabs[section.tab-index];
        frame: section.frame;
    }

    if (tab-open) && (tab-type == TabType.board-2d): Board2dTab {
        x: 0;
        y: tab-bar.height;
        width: 100%;
        height: parent.height - self.y;
        section-id: section.id;
        tab-index: section.tab-index;
        tab: section.tabs[section.tab-index];
        frame: section.frame;
    }

    if (tab-open) && (tab-type == TabType.board-3d): Board3dTab {
        x: 0;
        y: tab-bar.height;
        width: 100%;
        height: parent.height - self.y;
        section-id: section.id;
        tab-index: section.tab-index;
        tab: section.tabs[section.tab-index];
        frame: section.frame;
    }
}
