import { ActionId, ProjectData, MainPage, TabData, TabType } from "./api/types.slint";
import { Data } from "./api/data.slint";
import { Menu, MenuItem, MenuSeparator } from "./common/menu.slint";
import { Palette, LineEdit, TabWidget } from "std-widgets.slint";
import { Backend } from "./api/backend.slint";

component MainMenuItem inherits Rectangle {
    in property <string> text <=> t-title.text;

    callback clicked <=> ta.clicked;

    width: t-title.preferred-width + 10px;
    background: ta.has-hover ? #505050 : #252525;

    t-title := Text {
        x: 5px;
        font-size: 15px;
    }

    ta := TouchArea { }
}

component MenuBarButton inherits TouchArea {
    in property icon <=> i.source;

    width: self.height;

    i := Image {
        width: root.pressed ? 90% : 100%;
        image-fit: contain;
        colorize: (!root.enabled) ? #606060 : (root.has-hover ? white : Palette.foreground);
    }
}

export component MenuBar inherits Rectangle {
    in property <length> sections-start-x;

    background: #252525;

    public function focus-search() {
        le-search.focus();
    }

    HorizontalLayout {
        padding-right: 4px;

        MainMenuItem {
            text: @tr("File");

            clicked => {
                menu-file.show();
            }

            menu-file := Menu {
                x: 0;
                y: parent.height;

                MenuItem {
                    text: @tr("New Project") + "...";
                    icon: @image-url("img/file-circle-plus.svg");
                    status-tip: @tr("Create a new project");
                    shortcuts: "Ctrl+N";

                    clicked => {
                        Backend.action-triggered(ActionId.project-new, -1);
                    }
                }

                MenuItem {
                    text: @tr("Open Project") + "...";
                    icon: @image-url("img/folder-open.svg");
                    status-tip: @tr("Open an existing project");
                    shortcuts: "Ctrl+O";

                    clicked => {
                        Backend.action-triggered(ActionId.project-open, -1);
                    }
                }

                MenuItem {
                    text: @tr("Import EAGLE Project") + "...";
                    status-tip: @tr("Import schematic/board from EAGLE *.sch/*.brd files");

                    clicked => {
                        Backend.action-triggered(ActionId.project-import-eagle, -1);
                    }
                }

                MenuItem {
                    text: @tr("Add Example Projects") + "...";
                    status-tip: @tr("Add some example projects to the workspace");

                    clicked => {
                        Backend.action-triggered(ActionId.project-import-examples, -1);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("New Library") + "...";
                    icon: @image-url("img/plus.svg");
                    status-tip: @tr("Create a new local workspace library");

                    clicked => {
                        Backend.action-triggered(ActionId.create-library-tab-open, -1);
                    }
                }

                MenuItem {
                    text: @tr("Download Library") + "...";
                    icon: @image-url("img/download.svg");
                    status-tip: @tr("Manually download an existing library from the Internet");

                    clicked => {
                        Backend.action-triggered(ActionId.download-library-tab-open, -1);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Rescan Workspace Libraries");
                    icon: @image-url("img/refresh.svg");
                    status-tip: @tr("Scan all workspace libraries to update the cache");
                    shortcuts: "F5";

                    clicked => {
                        Backend.action-triggered(ActionId.rescan-workspace-libraries, -1);
                    }
                }

                MenuItem {
                    text: @tr("Open Workspace Folder");
                    status-tip: @tr("Open the workspace directory in the file manager");

                    clicked => {
                        Backend.action-triggered(ActionId.open-workspace-folder, -1);
                    }
                }

                MenuItem {
                    text: @tr("Switch Workspace") + "...";
                    status-tip: @tr("Choose another workspace to open");
                }

                MenuItem {
                    text: @tr("Preferences") + "...";
                    icon: @image-url("img/settings.svg");
                    status-tip: @tr("Open the workspace settings dialog");
                    shortcuts: "Ctrl+,";

                    clicked => {
                        Backend.action-triggered(ActionId.open-workspace-settings, -1);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Quit");
                    icon: @image-url("img/box-arrow-left.svg");
                    status-tip: @tr("Close all windows & quit the application");
                    shortcuts: "Ctrl+Q";

                    clicked => {
                        Backend.action-triggered(ActionId.quit, -1);
                    }
                }
            }
        }

        MainMenuItem {
            text: @tr("Edit");

            clicked => {
                menu-edit.show();
            }

            menu-edit := Menu {
                x: 0;
                y: parent.height;

                MenuItem {
                    text: Data.current-tab.undo-text.is-empty ? @tr("Undo") : @tr("Undo: {}", Data.current-tab.undo-text);
                    icon: @image-url("img/undo.svg");
                    status-tip: @tr("Revert the last modification");
                    shortcuts: "Ctrl+Z";
                    enabled: Data.current-tab.can-undo;

                    clicked => {
                        Backend.action-triggered(ActionId.undo, Data.current-section-index);
                    }
                }

                MenuItem {
                    text: Data.current-tab.redo-text.is-empty ? @tr("Redo") : @tr("Redo: {}", Data.current-tab.redo-text);
                    icon: @image-url("img/redo.svg");
                    status-tip: @tr("Re-apply the last reverted modification");
                    shortcuts: "Ctrl+Y";
                    enabled: Data.current-tab.can-redo;

                    clicked => {
                        Backend.action-triggered(ActionId.redo, Data.current-section-index);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Select All");
                    status-tip: @tr("Select all visible objects");
                    shortcuts: "Ctrl+A";
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Cut");
                    icon: @image-url("img/cut.svg");
                    status-tip: @tr("Cut the selected object(s) to clipboard");
                    shortcuts: "Ctrl+X";
                }

                MenuItem {
                    text: @tr("Copy");
                    icon: @image-url("img/copy.svg");
                    status-tip: @tr("Copy the selected object(s) to clipboard");
                    shortcuts: "Ctrl+C";
                }

                MenuItem {
                    text: @tr("Paste");
                    icon: @image-url("img/paste.svg");
                    status-tip: @tr("Paste object(s) from the clipboard");
                    shortcuts: "Ctrl+V";
                }

                MenuItem {
                    text: @tr("Remove");
                    icon: @image-url("img/delete.svg");
                    status-tip: @tr("Remove the selected object(s)");
                    shortcuts: "Del";
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Rotate Counterclockwise");
                    icon: @image-url("img/rotate-ccw.svg");
                    status-tip: @tr("Rotate the selected object(s) counterclockwise");
                    shortcuts: "R";
                }

                MenuItem {
                    text: @tr("Rotate Clockwise");
                    icon: @image-url("img/rotate-cw.svg");
                    status-tip: @tr("otate the selected object(s) clockwise");
                    shortcuts: "Shift+R";
                }

                MenuItem {
                    text: @tr("Mirror Horizontally");
                    icon: @image-url("img/mirror-horizontal.svg");
                    status-tip: @tr("Mirror the selected object(s) horizontally");
                    shortcuts: "M";
                }

                MenuItem {
                    text: @tr("Mirror Vertically");
                    icon: @image-url("img/mirror-vertical.svg");
                    status-tip: @tr("Mirror the selected object(s) vertically");
                    shortcuts: "Shift+M";
                }

                MenuItem {
                    text: @tr("Reset All Texts");
                    icon: @image-url("img/reset.svg");
                    status-tip: @tr("Reset all texts of the selected object(s) to their initial state");
                    shortcuts: "";
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Find");
                    icon: @image-url("img/search.svg");
                    status-tip: @tr("Find or filter objects");
                    shortcuts: "Ctrl+F";
                }

                MenuItem {
                    text: @tr("Find Next");
                    status-tip: @tr("Go to the next found object");
                    shortcuts: "F3";
                }

                MenuItem {
                    text: @tr("Find Previous");
                    status-tip: @tr("Go to the previous found object");
                    shortcuts: "Shift+F3";
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Properties");
                    icon: @image-url("img/edit.svg");
                    status-tip: @tr("View/modify the object properties");
                    shortcuts: "E";
                }
            }
        }

        MainMenuItem {
            text: @tr("View");

            clicked => {
                menu-view.show();
            }

            menu-view := Menu {
                x: 0;
                y: parent.height;

                MenuItem {
                    text: @tr("New Window");
                    icon: @image-url("img/window-plus.svg");
                    status-tip: @tr("Open a new window");

                    clicked => {
                        Backend.action-triggered(ActionId.window-new, -1);
                    }
                }

                MenuItem {
                    text: @tr("Close Window");
                    icon: @image-url("img/window-x.svg");
                    status-tip: @tr("Close this window");
                    shortcuts: "Alt+F4";

                    clicked => {
                        Backend.action-triggered(ActionId.window-close, -1);
                    }
                }

                MenuItem {
                    text: @tr("Split Window");
                    icon: @image-url("img/window-split.svg");
                    status-tip: @tr("Split the current window into one more section");

                    clicked => {
                        Backend.action-triggered(ActionId.section-split, Data.current-section-index);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Grid Properties");
                    icon: @image-url("img/grid-lines.svg");
                    status-tip: @tr("View/modify the grid properties");
                    shortcuts: "F4";
                    enabled: Data.current-tab-is-2d;
                }

                MenuItem {
                    text: @tr("Increase Grid Interval");
                    status-tip: @tr("Increase the grid interval");
                    shortcuts: "Ctrl+Shift++";
                    enabled: Data.current-tab-is-2d;

                    clicked => {
                        Backend.action-triggered(ActionId.section-grid-interval-increase, Data.current-section-index);
                    }
                }

                MenuItem {
                    text: @tr("Decrease Grid Interval");
                    status-tip: @tr("Decrease the grid interval");
                    shortcuts: "Ctrl+Shift+-";
                    enabled: Data.current-tab-is-2d;

                    clicked => {
                        Backend.action-triggered(ActionId.section-grid-interval-decrease, Data.current-section-index);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Show Pin Numbers");
                    status-tip: @tr("Show or hide symbol pin numbers");
                    enabled: Data.current-tab.type == TabType.schematic;
                    checked: Data.current-section.schematic-tabs[Data.current-section.current-tab-index].show-pin-numbers;

                    clicked => {
                        Data.current-section.schematic-tabs[Data.current-section.current-tab-index].show-pin-numbers = !Data.current-section.schematic-tabs[Data.current-section.current-tab-index].show-pin-numbers;
                    }
                }

                MenuItem {
                    text: @tr("Hide All Planes");
                    status-tip: @tr("Make the filled areas of all planes invisible");
                    enabled: Data.current-tab.type == TabType.board-2d;
                }

                MenuItem {
                    text: @tr("Show All Planes");
                    status-tip: @tr("Make the filled areas of all planes visible");
                    enabled: Data.current-tab.type == TabType.board-2d;
                }

                MenuItem {
                    text: @tr("Rebuild all Planes");
                    status-tip: @tr("Re-calculate the filled area of all planes");
                    shortcuts: "Ctrl+Shift+R";
                }

                MenuItem {
                    text: @tr("Ignore Placement Locks");
                    icon: @image-url("img/lock-closed.svg");
                    status-tip: @tr("Allow dragging locked objects");
                    shortcuts: "Ctrl+Shift+L";
                    enabled: Data.current-tab.type == TabType.board-2d;
                    checked: Data.ignore-placement-locks;

                    clicked => {
                        Data.ignore-placement-locks = !Data.ignore-placement-locks;
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Toggle 2D/3D Mode");
                    icon: @image-url("img/3d.svg");
                    status-tip: @tr("Switch between the 2D and 3D viewer mode");
                    shortcuts: "Ctrl+3";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);

                    clicked => {
                        Backend.action-triggered(ActionId.board-2d-tab-open-3d, Data.current-section-index);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("Zoom In");
                    icon: @image-url("img/zoom-in.svg");
                    status-tip: @tr("Increase the zoom level");
                    shortcuts: "Ctrl++";
                    enabled: Data.current-tab-is-2d-or-3d;
                }

                MenuItem {
                    text: @tr("Zoom Out");
                    icon: @image-url("img/zoom-out.svg");
                    status-tip: @tr("Decrease the zoom level");
                    shortcuts: "Ctrl+-";
                    enabled: Data.current-tab-is-2d-or-3d;
                }

                MenuItem {
                    text: @tr("Zoom to Fit Contents");
                    icon: @image-url("img/zoom-fit.svg");
                    status-tip: @tr("Set the zoom level to fit the whole content");
                    shortcuts: "Ctrl+Home";
                    enabled: Data.current-tab-is-2d-or-3d;
                }
            }
        }

        MainMenuItem {
            text: @tr("Project");

            clicked => {
                menu-extras.show();
            }

            menu-extras := Menu {
                x: 0;
                y: parent.height;

                MenuItem {
                    text: @tr("Save Project");
                    icon: @image-url("img/save.svg");
                    status-tip: @tr("Save all project modifications to disk, from all schematics & boards");
                    shortcuts: "Ctrl+S";
                    enabled: Data.projects[Data.current-tab.project-index].valid && Data.current-tab.can-save;

                    clicked => {
                        Backend.action-triggered(ActionId.save, Data.current-section-index);
                    }
                }

                MenuItem {
                    text: @tr("Update Project Library") + "...";
                    icon: @image-url("img/refresh.svg");
                    status-tip: @tr("Update the project's library elements from workspace libraries");
                    shortcuts: "Ctrl+F5";
                    enabled: Data.projects[Data.current-tab.project-index].valid;
                }

                MenuItem {
                    text: @tr("Project Setup") + "...";
                    icon: @image-url("img/settings.svg");
                    status-tip: @tr("View/modify the project setup");
                    shortcuts: "F6";
                    enabled: Data.projects[Data.current-tab.project-index].valid;
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("New Sheet") + "...";
                    icon: @image-url("img/file-circle-plus.svg");
                    status-tip: @tr("Add a new schematic sheet to the project");
                    shortcuts: "Ctrl+N";
                    enabled: Data.projects[Data.current-tab.project-index].valid;
                }

                MenuItem {
                    text: @tr("Rename Sheet") + "...";
                    status-tip: @tr("Rename the current schematic sheet");
                    shortcuts: "Ctrl+F2";
                    enabled: Data.current-tab.type == TabType.schematic;
                }

                MenuItem {
                    text: @tr("Remove Sheet") + "...";
                    icon: @image-url("img/delete.svg");
                    status-tip: @tr("Remove the current schematic sheet from the project");
                    shortcuts: "Ctrl+Del";
                    enabled: Data.current-tab.type == TabType.schematic;
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("New Board") + "...";
                    icon: @image-url("img/file-circle-plus.svg");
                    status-tip: @tr("Add a new board to the project");
                    shortcuts: "Ctrl+N";
                    enabled: Data.projects[Data.current-tab.project-index].valid;
                }

                MenuItem {
                    text: @tr("Copy Board") + "...";
                    icon: @image-url("img/copy.svg");
                    status-tip: @tr("Add a copy of the current board to the project");
                    shortcuts: "Ctrl+D";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);
                }

                MenuItem {
                    text: @tr("Remove Board") + "...";
                    icon: @image-url("img/delete.svg");
                    status-tip: @tr("Remove the current board from the project");
                    shortcuts: "Ctrl+Del";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);
                }

                MenuItem {
                    text: @tr("Run Quick Check");
                    icon: @image-url("img/output-jobs.svg");
                    status-tip: @tr("Run only the most important copper checks from the DRC");
                    shortcuts: "Shift+F8";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);
                }

                MenuItem {
                    text: @tr("Run Design Rule Check");
                    icon: @image-url("img/drc.svg");
                    status-tip: @tr("Run the design rule check (DRC)");
                    shortcuts: "F8";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);
                }

                MenuItem {
                    text: @tr("Board Setup") + "...";
                    icon: @image-url("img/settings.svg");
                    status-tip: @tr("View/modify the board setup");
                    shortcuts: "F7";
                    enabled: (Data.current-tab.type == TabType.board-2d) || (Data.current-tab.type == TabType.board-3d);
                }
            }
        }

        MainMenuItem {
            text: @tr("Help");

            clicked => {
                menu-help.show();
            }

            menu-help := Menu {
                x: 0;
                y: parent.height;

                MenuItem {
                    text: @tr("Keyboard Shortcuts Reference") + "...";
                    icon: @image-url("img/keyboard-shortcuts.svg");
                    status-tip: @tr("Open a quick reference about the keyboard shortcuts");
                    shortcuts: "Ctrl+F1";

                    clicked => {
                        Backend.action-triggered(ActionId.open-keyboard-shortcuts-reference, -1);
                    }
                }

                MenuItem {
                    text: @tr("User Manual & Tutorials") + "...";
                    icon: @image-url("img/documentation.svg");
                    status-tip: @tr("Open the user manual in the web browser");
                    shortcuts: "F1";

                    clicked => {
                        Backend.action-triggered(ActionId.open-user-manual, -1);
                    }
                }

                MenuItem {
                    text: @tr("Give Feedback & Get Support") + "...";
                    icon: @image-url("img/comments.svg");
                    status-tip: @tr("Open the support page in the web browser");

                    clicked => {
                        Backend.action-triggered(ActionId.open-support, -1);
                    }
                }

                MenuItem {
                    text: @tr("LibrePCB Website") + "...";
                    icon: @image-url("img/webbrowser.svg");
                    status-tip: @tr("Open the LibrePCB website in the web browser");

                    clicked => {
                        Backend.action-triggered(ActionId.open-website, -1);
                    }
                }

                MenuSeparator { }

                MenuItem {
                    text: @tr("About LibrePCB");
                    icon: @image-url("img/help.svg");
                    status-tip: @tr("Show information about this application");

                    clicked => {
                        Data.current-page = MainPage.help;
                    }
                }
            }
        }

        Rectangle {
            width: 3px;
        }

        Rectangle {
            y: 4px;
            width: 1px;
            height: parent.height - 2 * self.y;
            background: #606060;
        }

        HorizontalLayout {
            padding-top: 5px;
            padding-bottom: 5px;
            padding-left: 8px;
            padding-right: 20px;
            spacing: 5px;

            MenuBarButton {
                enabled: Data.current-tab.can-save;
                icon: @image-url("img/save.svg");

                clicked => {
                    Backend.action-triggered(ActionId.save, Data.current-section-index);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-export-graphics;
                icon: @image-url("img/pdf.svg");

                clicked => {
                    Backend.action-triggered(ActionId.export-pdf, Data.current-section-index);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-export-graphics;
                icon: @image-url("img/print.svg");

                clicked => {
                    Backend.action-triggered(ActionId.print, Data.current-section-index);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-undo;
                icon: @image-url("img/undo.svg");

                clicked => {
                    Backend.action-triggered(ActionId.undo, Data.current-section-index);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-redo;
                icon: @image-url("img/redo.svg");

                clicked => {
                    Backend.action-triggered(ActionId.redo, Data.current-section-index);
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;

            if Data.sections[Data.current-section-index].tabs.length > 0: HorizontalLayout {
                property <length> total-space: root.width - sections-start-x;
                property <length> section-width: total-space / Data.sections.length;
                property <length> offset: sections-start-x - parent.x - (self.width / 2);

                x: max(min(section-width * (0.5 + Data.current-section-index) + offset, parent.width - self.width - 10px), 0);
                width: self.preferred-width;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 5px;

                if Data.current-tab.can-cut-copy: MenuBarButton {
                    icon: @image-url("img/cut.svg");
                }

                if Data.current-tab.can-cut-copy: MenuBarButton {
                    icon: @image-url("img/copy.svg");
                }

                if Data.current-tab.can-paste: MenuBarButton {
                    icon: @image-url("img/paste.svg");
                }

                if Data.current-tab.can-remove: MenuBarButton {
                    icon: @image-url("img/delete.svg");
                }

                if Data.current-tab.can-rotate: MenuBarButton {
                    icon: @image-url("img/rotate-ccw.svg");
                }

                if Data.current-tab.can-rotate: MenuBarButton {
                    icon: @image-url("img/rotate-cw.svg");
                }

                if Data.current-tab.can-mirror: MenuBarButton {
                    icon: @image-url("img/mirror-horizontal.svg");
                }

                if Data.current-tab.can-mirror: MenuBarButton {
                    icon: @image-url("img/mirror-vertical.svg");
                }

                if Data.current-project.valid: MenuBarButton {
                    icon: @image-url("img/move.svg");
                }

                if Data.current-project.valid: MenuBarButton {
                    icon: @image-url("img/grid-dots.svg");
                }

                if Data.current-project.valid: MenuBarButton {
                    icon: @image-url("img/reset.svg");
                }

                if Data.current-project.valid: MenuBarButton {
                    icon: @image-url("img/lock-open.svg");
                }

                if Data.current-project.valid: MenuBarButton {
                    icon: @image-url("img/edit.svg");
                }
            }
        }

        le-search := LineEdit {
            y: 2px;
            height: parent.height - 2 * self.y;
            horizontal-stretch: 0;
            font-size: 11px;
            placeholder-text: @tr("Quick Find (Ctrl+F)");

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    self.clear-focus();
                    return accept;
                }
                return reject;
            }
        }
    }
}
