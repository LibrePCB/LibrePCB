import { Data } from "../api.slint";

export component WizardHeaderPanel inherits Rectangle {
    background: Data.theme.control;
    border-color: Data.theme.control-border;
    border-width: 1px;
    border-radius: 5px;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        @children
    }
}

export component WizardHeaderText inherits Text {
    color: Data.theme.control-text;
    font-size: 12px;
    wrap: word-wrap;
}

export component WizardHeader inherits WizardHeaderPanel {
    in property <string> text;

    WizardHeaderText {
        text: text;
    }
}
