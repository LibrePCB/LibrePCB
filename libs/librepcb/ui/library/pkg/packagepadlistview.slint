import { IconButton, LineEdit, ScrollView } from "../../widgets.slint";
import { Data, PackagePadData } from "../../api.slint";

component HorizontalLine inherits Rectangle {
    in property <bool> read-only: false;

    height: 1px;
    background: {
        if read-only {
            Data.theme.control-border-disabled
        } else {
            Data.theme.control-border-disabled
        }
    };
}

component VerticalLine inherits Rectangle {
    in property <bool> read-only: false;

    width: 1px;
    background: {
        if read-only {
            Data.theme.control-border-disabled
        } else {
            Data.theme.control-border-disabled
        }
    };
}

component PackagePadListViewTextCell inherits Rectangle {
    in property <string> text;
    in property <string> font-family;
    in property <length> font-size: 12px;
    in property <TextHorizontalAlignment> horizontal-alignment: left;

    preferred-width: txt.preferred-width + 10px;
    background: Data.theme.window;

    txt := Text {
        x: 5px;
        width: parent.width - 10px;
        horizontal-alignment: horizontal-alignment;
        vertical-alignment: center;
        font-family: font-family;
        font-size: font-size;
        color: Data.theme.control-text;
        text: text;
        accessible-role: none;
    }
}

export component PackagePadListView inherits ScrollView {
    in-out property <[PackagePadData]> model;
    in property <bool> read-only;
    property <length> row-height: 25px;
    property <bool> show-ids: self.width > 350px;

    callback edited;

    min-height: min(l.preferred-height, 3 * row-height);
    preferred-height: l.preferred-height;
    mouse-drag-pan-enabled: true;

    l := VerticalLayout {
        padding-right: 8px;  // Reserve space for the scrollbar

        HorizontalLayout {

            VerticalLine {
                read-only: read-only;
            }

            VerticalLayout {
                width: self.preferred-width;

                HorizontalLine {
                    read-only: read-only;
                }

                PackagePadListViewTextCell {
                    height: row-height;
                    horizontal-alignment: right;
                    text: "#";
                }

                for item[index] in model: VerticalLayout {
                    HorizontalLine {
                        read-only: read-only;
                    }

                    number-cell := PackagePadListViewTextCell {
                        height: row-height;
                        background: Data.theme.control;
                        horizontal-alignment: right;
                        font-size: 10px;
                        text: index + 1;
                    }
                }
            }

            VerticalLine {
                read-only: read-only;
            }

            if show-ids: VerticalLayout {
                width: self.preferred-width;

                HorizontalLine {
                    read-only: read-only;
                }

                PackagePadListViewTextCell {
                    height: row-height;
                    text: @tr("ID");
                }

                for item[index] in model: VerticalLayout {
                    HorizontalLine {
                        read-only: read-only;
                    }

                    id-cell := PackagePadListViewTextCell {
                        height: row-height;
                        background: Data.theme.control;
                        horizontal-alignment: right;
                        font-family: "Noto Sans Mono";
                        font-size: 10px;
                        text: item.id;
                    }
                }
            }

            if show-ids: VerticalLine {
                read-only: read-only;
            }

            VerticalLayout {
                HorizontalLine {
                    read-only: read-only;
                }

                name-header := PackagePadListViewTextCell {
                    height: row-height;
                    text: @tr("Name");
                }

                for item[index] in model: VerticalLayout {
                    HorizontalLine {
                        read-only: read-only;
                    }

                    name-edt := LineEdit {
                        height: row-height;
                        text: item.name;
                        validation-error: item.name-error;
                        read-only: read-only;
                        frameless: true;
                        accessible-label: name-header.text;

                        text-edited(text) => {
                            model[index].name = text;
                        }

                        text-accepted(text) => {
                            model[index].name = text;
                            edited();
                        }
                    }
                }
            }

            VerticalLine {
                read-only: read-only;
            }

            if !read-only: VerticalLayout {
                width: self.preferred-width;

                HorizontalLine {
                    read-only: read-only;
                }

                PackagePadListViewTextCell {
                    height: row-height;
                    min-width: row-height;
                }

                for item[index] in model: VerticalLayout {
                    HorizontalLine {
                        read-only: read-only;
                    }

                    delete-btn := IconButton {
                        height: row-height;
                        background-color: Data.theme.control;
                        icon-scale: 0.6;
                        icon: @image-url("../../../../font-awesome/svgs/solid/trash-can.svg");

                        clicked => {
                            model[index].delete = true;
                        }
                    }
                }
            }

            if !read-only: VerticalLine {
                read-only: read-only;
            }
        }

        HorizontalLine {
            read-only: read-only;
        }

        if model.length == 0: HorizontalLayout {
            VerticalLine {
                read-only: read-only;
            }

            Rectangle {
                height: row-height;
                background: Data.theme.control;

                no-pads-txt := Text {
                    width: parent.width - 10px;
                    horizontal-alignment: left;
                    wrap: word-wrap;
                    color: Data.theme.control-text-muted;
                    font-italic: true;
                    text: @tr("This package contains no pads (yet).");
                }
            }

            VerticalLine {
                read-only: read-only;
            }
        }

        if model.length == 0: HorizontalLine {
            read-only: read-only;
        }
    }
}
