import {
    Button,
    LinkText,
    MessageBanner,
} from "../widgets.slint";
import {
    Data,
    EditorCommandSet as Cmd,
    TabAction,
} from "../api.slint";

export component BreakingChangesMessageBanner inherits MessageBanner {
    in property <bool> unlocked;

    background: Data.theme.error;
    text-color: Data.theme.error-text;

    callback action-invoked(action: TabAction);

    l := HorizontalLayout {
        spacing: 5px;

        VerticalLayout {
            alignment: center;

            Text {
                color: root.text-color;
                font-weight: 700;
                horizontal-alignment: left;
                wrap: word-wrap;
                text: @tr("Attention").to-uppercase() + ": " + @tr("Some of the applied modifications are not backward-compatible!");
            }

            Text {
                color: root.text-color;
                horizontal-alignment: left;
                wrap: word-wrap;
                font-italic: unlocked;
                text: {
                    if unlocked {
                        @tr("You have removed the write protection. Keep in mind: With great power comes great responsibility!")
                    } else {
                        @tr("To avoid breaking other library elements or projects which reference this element, the editor has been put into read-only mode and saving is not possible anymore. Either undo the breaking changes, or duplicate this library element and make the modifications in the new library element.")
                    }
                };
            }
        }

        VerticalLayout {
            width: self.preferred-width;
            alignment: center;
            spacing: 5px;

            duplicate-btn := Button {
                icon: @image-url("../../../font-awesome/svgs/solid/arrow-up-right-from-square.svg");
                text: @tr("Duplicate");
                status-tip: @tr("Create a new library element by duplicating this one");
                primary: true;

                clicked => {
                    action-invoked(TabAction.save-as);
                }
            }

            if !unlocked: unlock-btn := Button {
                icon: @image-url("../../../font-awesome/svgs/solid/lock-open.svg");
                text: @tr("Unlock the fiasco").to-uppercase();
                status-tip: @tr("DANGER: Press & hold to remove the read-only protection and allow making breaking changes");

                if self.pressed: Rectangle {
                    width: parent.width - 4px;
                    height: parent.height - 4px;
                    background: Data.theme.control;

                    Rectangle {
                        property <float> progress: 0.2;

                        x: 0;
                        width: parent.width * min(progress, 1);
                        background: Data.theme.error;

                        Timer {
                            running: true;
                            interval: 15ms;

                            triggered => {
                                progress = progress + 0.01;
                                if progress > 1 {
                                    self.running = false;
                                    action-invoked(TabAction.unlock);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component ElementDuplicatedMessageBanner inherits MessageBanner {
    background: Data.theme.info;

    callback deprecate-clicked <=> deprecate-btn.clicked;
    callback cancel-clicked <=> cancel-btn.clicked;

    HorizontalLayout {
        spacing: 5px;

        VerticalLayout {
            alignment: center;

            Text {
                color: Data.theme.info-text;
                horizontal-alignment: left;
                wrap: word-wrap;
                text: @tr("This library element has been duplicated. Mark it as deprecated?");
            }
        }

        deprecate-btn := Button {
            y: (parent.height - self.height) / 2;
            width: self.preferred-width;
            text: @tr("Deprecate");
            status-tip: @tr("Mark this library element as deprecated");
            border-width: 1px;
            primary: true;
        }

        cancel-btn := Button {
            y: (parent.height - self.height) / 2;
            width: self.preferred-width;
            text: @tr("Cancel");
        }
    }
}

export component CheckErrorsMessageBanner inherits MessageBanner {
    text: @tr("Attention").to-uppercase() + ": " + @tr("This library element contains serious errors. Please review them in the rule check panel.");
}

export component FilesModifiedMessageBanner inherits MessageBanner {
    background: Data.theme.info;

    callback reload-clicked <=> reload-btn.clicked;

    HorizontalLayout {
        spacing: 5px;

        VerticalLayout {
            alignment: center;

            Text {
                color: Data.theme.info-text;
                horizontal-alignment: left;
                wrap: word-wrap;
                text: @tr("The files have been modified on disk. It is recommended to close and reopen this tab to see the modifications.");
            }

            Text {
                color: Data.theme.info-text;
                font-weight: 700;
                horizontal-alignment: left;
                wrap: word-wrap;
                text: @tr("Note that the reload feature is currently considered experimental.");
            }
        }

        reload-btn := Button {
            y: (parent.height - self.height) / 2;
            width: self.preferred-width;
            text: @tr("Reload");
            status-tip: @tr("Discard modifications (if any) and reload the modified files from disk");
        }
    }
}
