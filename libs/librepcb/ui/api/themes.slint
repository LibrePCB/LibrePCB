export struct Palette {
    bg: color, // window
    bg2: color, // menu bar, side bar, status bar
    bg3: color, // controls
    bg2-hovered: color,
    bg2-checked: color,
    bg-border: color,

    tooltip-bg: color,
    tooltip-fg: color,
    tooltip-border: color,


    fg: color, // text/icons on bg
    fg-placeholder: color,
    fg-disabled: color, // text/icons on bg
    fg-hovered: color,
    fg-success: color, // text/icons on bg
    fg-warning: color, // text/icons on bg
    fg-error: color, // text/icons on bg
}

export struct Theme {
    palette: Palette,
}

export global Themes {
    out property <Theme> dark: {
        palette: {
            bg: #2a2a2a,
            bg2: #353535,
            bg3: #303030,
            bg2-hovered: #424242,
            bg2-checked: #2a2a2a,
            bg-border: #404040,
            tooltip-bg: #1a1a1a,
            tooltip-fg: #d8d8d8,
            tooltip-border: #909090,
            fg: #c4c4c4,
            fg-placeholder: #909090,
            fg-disabled: #707070,
            fg-hovered: #e0e0e0,
            fg-success: Colors.lime,
            fg-warning: Colors.yellow,
            fg-error: #ff7070,
        },
    };

    out property <Theme> light: {
        palette: {
            bg: #ffffff,
            bg2: #e0e0e0,
            bg3: #f5f5f5,
            bg2-hovered: #e8e8e8,
            bg2-checked: #d0d0d0,
            bg-border: #d0d0d0,
            tooltip-bg: #fffbc5,
            tooltip-fg: #3a3a3a,
            tooltip-border: #b9b9b9,
            fg: #292929,
            fg-placeholder: #808080,
            fg-disabled: #b0b0b0,
            fg-hovered: #000000,
            fg-success: #00d800,
            fg-warning: #d6c800,
            fg-error: Colors.red,
        },
    };
}
