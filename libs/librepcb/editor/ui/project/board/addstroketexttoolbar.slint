import { ComboBox, LineEdit, Palette, Switch } from "std-widgets.slint";
import { LengthEdit } from "../../common/lengthedit.slint";
import { WindowSectionData, Board2dTabData, Int64 } from "../../api/types.slint";

export component AddStrokeTextToolBar inherits HorizontalLayout {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[Board2dTabData]> tabs: section.board-2d-tabs;

    spacing: 5px;

    Text {
        vertical-alignment: center;
        text: @tr("Layer:");
    }

    ComboBox {
        model: tabs[section.current-tab-index].tool-layer.items;
        current-index: tabs[section.current-tab-index].tool-layer.current-index;

        changed current-index => {
            if (tabs[section.current-tab-index].tool-layer.current-index != self.current-index) {
                tabs[section.current-tab-index].tool-layer.current-index = self.current-index;
            }
        }
    }

    Text {
        vertical-alignment: center;
        text: @tr("Text:");
    }

    LineEdit {
        property <string> tool-value: tabs[section.current-tab-index].tool-value.text;
        property <bool> disable-update: false;

        changed tool-value => {
            if !disable-update {
                self.text = tool-value;
            }
        }

        changed has-focus => {
            if !self.has-focus {
                disable-update = false;
                self.text = tool-value;
            }
        }

        init => {
            self.text = tool-value;
        }

        edited(text) => {
            disable-update = true;
            tabs[section.current-tab-index].tool-value.text = text;
        }
    }

    TouchArea {
        width: 10px;

        Text {
            font-size: parent.has-hover ? 10px : 8px;
            color: parent.has-hover ? white : #cccccc;
            text: "▼";
        }

        popup-suggestions := PopupWindow {
            x: 0;
            y: root.height;

            VerticalLayout {
                for text in tabs[section.current-tab-index].tool-value.suggestions: TouchArea {
                    Rectangle {
                        background: parent.has-hover ? #505050 : Palette.background;

                        VerticalLayout {
                            padding: 6px;

                            Text {
                                text: text;
                            }
                        }
                    }

                    clicked => {
                        tabs[section.current-tab-index].tool-value.text = text;
                    }
                }
            }
        }

        clicked => {
            popup-suggestions.show();
        }
    }

    Text {
        vertical-alignment: center;
        text: @tr("Height:");
    }

    LengthEdit {
        value: tabs[section.current-tab-index].tool-size.value;
        unit: tabs[section.current-tab-index].tool-size.unit;
        can-decrease: tabs[section.current-tab-index].tool-size.can-decrease;

        value-entered(v) => {
            tabs[section.current-tab-index].tool-size.value = v;
        }

        unit-entered(u) => {
            tabs[section.current-tab-index].tool-size.unit = u;
        }

        increase-triggered => {
            tabs[section.current-tab-index].tool-size.increase = true;
        }

        decrease-triggered => {
            tabs[section.current-tab-index].tool-size.decrease = true;
        }
    }

    Text {
        vertical-alignment: center;
        text: @tr("Mirror:");
    }

    Switch {
        checked: tabs[section.current-tab-index].tool-mirrored;

        toggled => {
            tabs[section.current-tab-index].tool-mirrored = self.checked;
        }
    }
}
