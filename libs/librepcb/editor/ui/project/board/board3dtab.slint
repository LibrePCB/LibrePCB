import { Action, WindowSectionData, Board3dTabData } from "../../api/types.slint";
import { SceneButton } from "../../widgets.slint";
import { Backend } from "../../api/backend.slint";
import { Data } from "../../api/data.slint";

export component Board3dTab inherits Image {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[Board3dTabData]> tabs: section.board-3d-tabs;
    property <int> index: section.current-tab-index;

    image-fit: ImageFit.preserve;
    image-rendering: ImageRendering.pixelated;
    source: Backend.render-scene(section-index, root.width, root.height, tabs[section.current-tab-index].frame);

    fs := FocusScope {
        changed has-focus => {
            if !self.has-focus {
                Backend.trigger(Action.focus-lost);
            }
        }
    }

    TouchArea {
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                Data.section-clicked(section-index);
                if (!fs.has-focus) {
                    fs.focus();
                }
            }
            return Backend.scene-pointer-event(section-index, self.mouse-x, self.mouse-y, self.absolute-position, e);
        }

        scroll-event(e) => {
            return Backend.scene-scrolled(section-index, self.mouse-x, self.mouse-y, e);
        }
    }

    VerticalLayout {
        x: parent.width - self.preferred-width - 10px;
        y: 10px;
        width: self.preferred-width;
        spacing: 5px;

        SceneButton {
            image: @image-url("../../../../../font-awesome/svgs/solid/expand.svg");
            bg-color: tabs[section.current-tab-index].overlay-color;
            fg-color: tabs[section.current-tab-index].overlay-text-color;
            clicked => {
                section.tabs[index].action = Action.zoom-fit;
            }
        }

        SceneButton {
            image: @image-url("../../../../../bootstrap-icons/icons/zoom-in.svg");
            bg-color: tabs[section.current-tab-index].overlay-color;
            fg-color: tabs[section.current-tab-index].overlay-text-color;
            clicked => {
                section.tabs[index].action = Action.zoom-in;
            }
        }

        SceneButton {
            image: @image-url("../../../../../bootstrap-icons/icons/zoom-out.svg");
            bg-color: tabs[section.current-tab-index].overlay-color;
            fg-color: tabs[section.current-tab-index].overlay-text-color;
            clicked => {
                section.tabs[index].action = Action.zoom-out;
            }
        }
    }
}
