import {
    Action,
    EditParseResult,
    Int64,
    LengthUnit
} from "types.slint";
import { Data } from "data.slint";

// Note: The callback implementations are just for the live preview, they will
// be overridden by the backend in the real use-case.
export global Backend {
    // Trigger some action
    //
    // Note: This callback is executed asynchronously in the backend to
    // guarantee there are no side effects changing the UI from within the
    // callback. Otherwise we couldn't declare it as 'pure'.
    pure callback trigger(action: Action);
    trigger(action) => {
        debug("Trigger action:", action);
    }

    pure callback parse-length-input(string, LengthUnit) -> EditParseResult;

    pure callback format-length(Int64, LengthUnit) -> string;
    format-length => {
        return "123.456789";
    }

    // A schematic in the projects panel has been clicked
    //
    // - Project index
    // - Schematic index
    pure callback schematic-clicked(int, int);

    // A board in the projects panel has been clicked
    //
    // - Project index
    // - Board index
    pure callback board-clicked(int, int);

    // Open an URL by an external application (usually the web browser)
    //
    // The return value indicates whether the operation was successful or not.
    pure callback open-url(url: string) -> bool;
    open-url(url) => {
        debug("Open URL:", url);
        true
    }

    // Copy a string into the clipboard
    //
    // The return value indicates whether the operation was successful or not.
    pure callback copy-to-clipboard(s: string) -> bool;
    copy-to-clipboard(s) => {
        Data.preview-mode  // Make it fail if callback not bound in backend.
    }

    // Key event on the libraries list
    //
    // Used for the filtering feature in the libraries panel.
    callback libraries-key-event(event: KeyEvent) -> EventResult;
    libraries-key-event(event) => {
        if event.text == Key.Escape {
            Data.libraries-filter = "";
        } else {
            Data.libraries-filter += event.text;
        }
        reject
    }

    // Render a graphics scene image
    //
    // - Section index
    // - Scene width
    // - Scene height
    // - Frame number (to be ignored)
    pure callback render-scene(int, length, length, int) -> image;

    // Scene pointer event
    //
    // - Section index
    // - Cursor position X (relative to scene)
    // - Cursor position Y (relative to scene)
    // - Scene location within window
    // - Pointer event
    pure callback scene-pointer-event(int, length, length, Point, PointerEvent) -> EventResult;

    // Scene scrolled event
    //
    // - Section index
    // - Cursor position X (relative to scene)
    // - Cursor position Y (relative to scene)
    // - Scroll event
    pure callback scene-scrolled(int, length, length, PointerScrollEvent) -> EventResult;

    // Scene key pressed event
    //
    // - Section index
    // - Key event
    pure callback scene-key-pressed(int, KeyEvent) -> EventResult;

    // Scene key released event
    //
    // - Section index
    // - Key event
    pure callback scene-key-released(int, KeyEvent) -> EventResult;

    // Scene button "zoom to fit content" clicked
    //
    // - Section index
    // - Scene width
    // - Scene height
    pure callback scene-zoom-fit-clicked(int, length, length);

    // Scene button "zoom in" clicked
    //
    // - Section index
    // - Scene width
    // - Scene height
    pure callback scene-zoom-in-clicked(int, length, length);

    // Scene button "zoom out" clicked
    //
    // - Section index
    // - Scene width
    // - Scene height
    pure callback scene-zoom-out-clicked(int, length, length);

    // Request generating the preview of a project (e.g. its README.md)
    //
    // Lets the backend building the preview asynchronously, and updating the
    // following data members accordingly:
    //  - Data.project-preview-rendering
    //  - Data.project-preview-image
    //
    // The return value is a dummy and must always be `true` to allow
    // declarative, automatic re-evaluation.
    pure callback request-project-preview(path: string, width: length) -> bool;
    request-project-preview(path, width) => {
        debug("Request project preview:", path, width);
        true
    }
}
