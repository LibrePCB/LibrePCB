export struct Int64 {
    msb: int,
    lsb: int,
}

export struct Layer {
    id: string,
    name: string,
}

export enum LengthUnit {
    millimeters,
    micrometers,
    nanometers,
    inches,
    mils,
}

export enum GridStyle {
    none,
    dots,
    lines,
}

export enum NotificationType {
    tip,
    info,
    warning,
    critical,
    progress,
}

export struct NotificationData {
    // Data from backend:
    type: NotificationType,
    title: string,
    description: string,
    button-text: string, // Optional
    progress: int,  // [%]

    // Features:
    supports-dont-show-again: bool,

    // Status:
    unread: bool,

    // Special function members:
    button-clicked: bool,  // If set by UI, backend shall handle it.
    dismissed: bool,  // If set by UI, backend shall delete notification.
    dont-show-again: bool,  // If set by UI, backend shall delete notification.
}

export struct RuleCheckMessageData {
    severity: NotificationType,
    message: string,
    description: string,
    approved: bool,
    supports-autofix: bool,
    autofix-requested: bool,  // Flag set by UI, reset by backend.
}

export enum LibraryType {
    local,
    remote,
    online,
}

export enum LibraryState {
    unknown,
    up-to-date,
    outdated,
}

export struct LibraryData {
    id: string,
    name: string,
    description: string,
    version: string,
    icon: image,
    recommended: bool,
    type: LibraryType,
    state: LibraryState,
    progress: int, // [%], 0 if not installing
    checked: bool,
    filtered-out: bool,
}

export struct FolderTreeItemData {
    level: int, // 0 = top level items
    icon: image,
    name: string,
    path: string,
    has-children: bool,
    expanded: bool,
    supports-pinning: bool,
    pinned: bool,
}

export struct QuickAccessItemData {
    name: string,
    path: string,
    pinned: bool,
}

export struct ProjectData {
    valid: bool,
    path: string,
    name: string,
    schematics: [string],
    boards: [string],
}

export enum TabType {
    home,
    create-library,
    download-library,
    schematic,
    board-2d,
    board-3d,
}

export enum RuleCheckState {
    not-available,
    not-run-yet,
    running,
    outdated,
    up-to-date,
}

export enum EditorTool {
    select,
    wire,
    netlabel,
    polygon,
    text,
    component,
    measure,
}

export struct TabData {
    // Meta
    type: TabType,
    title: string,
    project-index: int,

    // Rule check
    rule-check-state: RuleCheckState,
    rule-check-messages: [RuleCheckMessageData],
    rule-check-execution-error: string,  // Empty if no error

    // Features
    can-save: bool,
    can-export-graphics: bool,
    can-undo: bool,
    undo-text: string,
    can-redo: bool,
    redo-text: string,
    can-cut: bool,
    can-copy: bool,
    can-paste: bool,
    can-remove: bool,
    can-rotate: bool,
    can-mirror: bool,
    can-move-align: bool,
    can-snap-to-grid: bool,
    can-reset-texts: bool,
    can-lock-placement: bool,
    can-edit-properties: bool,
}

export struct CreateLibraryTabData {
    name: string,
    name-error: string,
    description: string,
    author: string,
    author-default: string,
    version: string,
    version-default: string,
    version-error: string,
    url: string,
    url-error: string,
    cc0: bool,
    directory: string,
    directory-default: string,
    directory-error: string,
    valid: bool,
    creation-error: string,
}

export struct DownloadLibraryTabData {
    url: string,
    url-error: string,
    url-suggestion: string,
    directory: string,
    directory-default: string,
    directory-error: string,
    valid: bool,
    download-running: bool,
    download-progress: int,
    download-error: string,
}

export enum WireMode {
    h-v,
    v-h,
    deg90-45,
    deg45-90,
    straight,
}

export struct SchematicTabData {
    background-color: brush,
    overlay-color: brush,
    overlay-text-color: brush,
    grid-style: GridStyle,
    grid-interval: string,
    unit: LengthUnit,
    show-pin-numbers: bool,

    // Data about the currently active tool.
    tool: EditorTool,
    tool-cursor: MouseCursor,
    tool-overlay-text: string,
    tool-wire-mode: WireMode,
    tool-layers: [string],
    tool-layer-index: int,
    tool-line-width: Int64,
    tool-line-width-unit: LengthUnit,
    tool-line-width-can-decrease: bool,
    tool-line-width-increase: bool,  // Set by UI, reset by backend.
    tool-line-width-decrease: bool,  // Set by UI, reset by backend.
    tool-height: Int64,
    tool-height-unit: LengthUnit,
    tool-height-can-decrease: bool,
    tool-height-increase: bool,  // Set by UI, reset by backend.
    tool-height-decrease: bool,  // Set by UI, reset by backend.
    tool-filled: bool,
    tool-value: string,
    tool-value-suggestions: [string],
    tool-attribute-value: string,
    tool-attribute-value-placeholder: string,
    tool-attribute-value-enabled: bool,
    tool-attribute-units: [string],
    tool-attribute-unit-index: int,

    scene-image-pos: Point,
    frame: int, // Frame index to trigger repainting.
}

export struct Board2dTabData {
    background-color: brush,
    overlay-color: brush,
    grid-style: GridStyle,
    grid-interval: string,
    unit: LengthUnit,

    frame: int, // Frame index to trigger repainting
}

export struct Board3dTabData {
    background-color: brush,
    overlay-color: brush,

    frame: int, // Frame index to trigger repainting
}

export struct WindowSectionData {
    tabs: [TabData], // Tabs in this section
    create-library-tabs: [CreateLibraryTabData],
    download-library-tabs: [DownloadLibraryTabData],
    schematic-tabs: [SchematicTabData],
    board-2d-tabs: [Board2dTabData],
    board-3d-tabs: [Board3dTabData],
    current-tab-index: int,  // Currently opened tab in this section
    highlight: bool,
}

export struct EditParseResult {
    valid: bool,
    evaluated-value: Int64,
    evaluated-unit: LengthUnit,
}
