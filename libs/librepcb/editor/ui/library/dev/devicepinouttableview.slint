import { ScrollView } from "std-widgets.slint";
import {
    Button,
    ComboBox,
    IconButton,
    LineEdit,
    LinkText,
    MenuItem,
    MenuPopup,
    MessageBox,
    Palette,
    SceneButton,
    SlideView,
    Switch,
    TextEdit,
    ToolButton,
    TreeItemPickerPopup,
} from "../../widgets.slint";
import {
    Backend,
    Constants,
    Data,
    DevicePinoutData,
    DismissableMessageAction,
    EditorCommandSet as Cmd,
    EditorTool,
    PanelPage,
    TabAction,
    WindowSectionData,
} from "../../api.slint";


export component DevicePinoutTableView {
    in-out property <[DevicePinoutData]> model;
    in-out property <[string]> signal-names;
    property <length> row-height: 25px;
    property <length> row-spacing: 3px;

    preferred-width: l.preferred-width;
    preferred-height: l.preferred-height;

    ScrollView {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;

        l := HorizontalLayout {
            spacing: 8px;
            padding-left: 20px;

            VerticalLayout {
                width: self.preferred-width;
                spacing: 2px;

                for pinout in model: Text {
                    height: row-height;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                    text: pinout.pad-name + ":";
                }
            }

            VerticalLayout {
                spacing: 2px;

                for pinout in model: ComboBox {
                    height: row-height;
                    model: signal-names;
                    current-index: pinout.signal-index;
                }
            }
        }
    }
}
