import { Tab } from "../../tab.slint";
import {
    Button,
    ComboBox,
    LineEdit,
    TextEdit,
    LinkText,
    MessageBox,
    Palette,
    SlideView,
    SceneButton,
    Switch,
    ToolButton,
} from "../../widgets.slint";
import {
    Backend,
    DeviceTabData,
    Constants,
    Data,
    DismissableMessageAction,
    EditorCommandSet as Cmd,
    EditorTool,
    PanelPage,
    TabAction,
    WindowSectionData,
} from "../../api.slint";

component DeviceMetadata inherits GridLayout {
    in property <int> section-index;
    in-out property <[DeviceTabData]> tabs;
    in property <int> index;

    padding: 10px;
    spacing: 8px;

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Name:");
        }

        LineEdit {
            text: tabs[index].name;
            //validation-error: tabs[index].name-error;

            text-edited(text) => {
                tabs[index].name = text;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Description:");
        }

        TextEdit {
            height: 100px;
            text: tabs[index].description;

            text-edited(text) => {
                tabs[index].description = text;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Keywords:");
        }

        LineEdit {
            text: tabs[index].keywords;

            text-edited(text) => {
                tabs[index].keywords = text;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Author:");
        }

        LineEdit {
            text: tabs[index].author;

            text-edited(text) => {
                tabs[index].author = text;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Version:");
        }

        LineEdit {
            text: tabs[index].version;
            //validation-error: tabs[index].version-error;

            text-edited(text) => {
                tabs[index].version = text;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Deprecated:");
        }

        Switch {
            font-size: 10px;
            text: @tr("Check this if the element should no longer be used.");
            checked: tabs[index].deprecated;

            toggled(checked) => {
                tabs[index].deprecated = checked;
            }
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Categories:");
        }

        TextEdit {
            enabled: false;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Datasheet:");
        }

        LineEdit {
            //text: tabs[index].datasheet;
            //validation-error: tabs[index].datasheet-error;

            //text-edited(text) => {
            //    tabs[index].datasheet = text;
            //}
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Attributes:");
        }

        TextEdit {
            height: 100px;
            enabled: false;
        }
    }

    Row {
        Rectangle { }
    }
}

export component DeviceTab inherits Tab {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[DeviceTabData]> tabs: section.device-tabs;
    property <int> index: section.current-tab-index;

    enabled: true;

    SlideView {
        pages: [@tr("Metadata"), @tr("Pinout"), @tr("Parts")];

        DeviceMetadata {
            width: parent.width;
            section-index: section-index;
            tabs: tabs;
            index: index;
        }

        Rectangle { }

        Rectangle { }
    }
}
