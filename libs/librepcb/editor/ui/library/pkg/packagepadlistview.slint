import {
    Button,
    CategoriesListView,
    ComboBox,
    IconButton,
    LineEdit,
    LinkText,
    MenuItem,
    MenuPopup,
    MessageBox,
    Palette,
    SceneButton,
    ScrollView,
    SlideView,
    Switch,
    TextEdit,
    ToolButton,
    TreeItemPickerPopup,
} from "../../widgets.slint";
import {
    Backend,
    Constants,
    Data,
    DismissableMessageAction,
    EditorCommandSet as Cmd,
    EditorTool,
    PackagePadData,
    PanelPage,
    TabAction,
    WindowSectionData,
} from "../../api.slint";


component PackagePadListViewHeader inherits TouchArea {
    in property <string> text;
    in property <TextHorizontalAlignment> alignment: left;
    in property <color> color: Palette.foreground;

    Text {
        width: 100%;
        horizontal-alignment: alignment;
        vertical-alignment: center;
        color: color;
        text: text;
    }
}

export component PackagePadListView {
    in-out property <[PackagePadData]> model;
    in-out property <string> new-name;
    in-out property <string> new-name-error;
    property <length> row-height: 25px;
    property <length> row-spacing: 3px;

    callback edited;
    callback new-signal-edited(text: string);
    new-signal-edited(text) => {
        new-name = text;
    }
    callback new-signal-committed();

    VerticalLayout {
        alignment: start;
        spacing: 10px;

        HorizontalLayout {
            padding: 5px;
            spacing: 5px;

            Text {
                height: row-height;
                vertical-alignment: center;
                text: @tr("Add Pads:");
            }

            new-pad-edt := LineEdit {
                height: row-height;
                placeholder-text: @tr("Pad name (may contain ranges like \"1..5\")");
                text: new-name;
                validation-error: new-name-error;

                text-edited(text) => {
                    new-signal-edited(text);
                }
                key-pressed(event) => {
                    if event.text == Key.Return {
                        new-pad-btn.clicked();
                        return accept;
                    }
                    reject
                }
            }

            new-pad-btn := IconButton {
                height: row-height;
                style: hyperlink;
                icon-scale: 0.7;
                icon: @image-url("../../../../../font-awesome/svgs/solid/plus.svg");

                clicked => {
                    new-signal-committed();
                }
            }
        }

        view := ScrollView {
            preferred-height: l.preferred-height;

            Rectangle {
                x: 0;
                y: row-height + 3px;
                height: 1px;
                background: #404040;
            }

            l := HorizontalLayout {
                padding: 5px;
                spacing: 5px;

                VerticalLayout {
                    width: self.preferred-width;
                    spacing: row-spacing;

                    PackagePadListViewHeader {
                        height: row-height;
                        alignment: right;
                        color: #909090;
                        text: @tr("#");
                    }

                    for item[index] in model: Text {
                        height: row-height;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        font-size: 10px;
                        color: #909090;
                        text: index + 1;
                    }
                }

                Rectangle {
                    width: 1px;
                    background: #404040;
                }

                VerticalLayout {
                    width: self.preferred-width;
                    spacing: row-spacing;

                    PackagePadListViewHeader {
                        height: row-height;
                        color: #909090;
                        text: @tr("ID");
                    }

                    for item[index] in model: Text {
                        height: row-height;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        font-family: "Noto Sans Mono";
                        font-size: 10px;
                        color: #909090;
                        text: item.id;
                    }
                }

                Rectangle {
                    width: 1px;
                    background: #404040;
                }

                VerticalLayout {
                    spacing: row-spacing;

                    PackagePadListViewHeader {
                        height: row-height;
                        text: @tr("Name");
                    }

                    for item[index] in model: LineEdit {
                        height: row-height;
                        text: item.name;
                        validation-error: item.name-error;

                        text-edited(text) => {
                            model[index].name = text;
                        }
                        text-accepted(text) => {
                            model[index].name = text;
                            edited();
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    background: #404040;
                }

                VerticalLayout {
                    spacing: row-spacing;

                    PackagePadListViewHeader {
                        height: row-height;
                    }

                    for item[index] in model: IconButton {
                        height: row-height;
                        style: hyperlink;
                        icon-scale: 0.7;
                        icon: @image-url("../../../../../font-awesome/svgs/solid/trash-can.svg");
                    }
                }
            }
        }
    }
}
