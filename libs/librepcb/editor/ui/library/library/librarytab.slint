import { TextEdit } from "std-widgets.slint";
import { Tab } from "../../tab.slint";
import {
    Button,
    ComboBox,
    LineEdit,
    LinkText,
    MessageBox,
    Palette,
    SceneButton,
    PanelHeader,
    Switch,
    ToolButton,
    TreeView,
} from "../../widgets.slint";
import {
    Backend,
    Constants,
    Data,
    DismissableMessageAction,
    TreeViewItemData,
    EditorCommandSet as Cmd,
    EditorTool,
    LibraryTabData,
    PanelPage,
    TabAction,
    WindowSectionData,
} from "../../api.slint";

component LibraryMetadataBox inherits Rectangle {
    in property <[LibraryTabData]> tabs;
    in property <int> index;

    //preferred-width: 400px;
    background: Palette.background;
    border-bottom-left-radius: 10px;

    GridLayout {
        padding: 10px;
        spacing: 8px;

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Name:");
            }

            LineEdit {
                text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Description:");
            }

            TextEdit {
                height: 100px;
                text: tabs[index].description;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Keywords:");
            }

            LineEdit {
                //text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Author:");
            }

            LineEdit {
                text: tabs[index].author;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Version:");
            }

            LineEdit {
                text: tabs[index].version;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Deprecated:");
            }

            Switch {
                font-size: 10px;
                text: @tr("Check this if the element should no longer be used.");
                checked: tabs[index].deprecated;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("URL:");
            }

            LineEdit {
                text: tabs[index].url;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Dependencies:");
            }

            TextEdit {
                height: 60px;
                //text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Manufacturer:");
            }

            LineEdit {
                text: tabs[index].manufacturer;
            }
        }

        Row {
            Rectangle { }
        }
    }
}

component LibraryTreeView inherits VerticalLayout {
    in property <string> title;
    in-out property <[TreeViewItemData]> model;

    PanelHeader {
        title: title;
    }

    TreeView {
        model: model;
    }
}

export component LibraryTab inherits Tab {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[LibraryTabData]> tabs: section.library-tabs;
    property <int> index: section.current-tab-index;
    property <bool> tabbed: self.width < 1024px;

    enabled: true;

    VerticalLayout {
        if tabbed: Rectangle {
            background: black;

            HorizontalLayout {
                padding: 8px;
                spacing: 15px;
                alignment: start;

                LinkText {
                    text: @tr("Metadata");

                    clicked => {
                        tabs[index].step-index = 0;
                    }
                }

                Text {
                    text: ">";
                }

                LinkText {
                    text: @tr("Content");

                    clicked => {
                        tabs[index].step-index = 1;
                    }
                }
            }
        }

        if tabbed: Flickable {
            viewport-width: self.width * 2;
            viewport-height: self.height;
            viewport-x: -self.width * tabs[index].step-index;

            animate viewport-x { duration: 30ms; }

            HorizontalLayout {
                LibraryMetadataBox {
                    width: 50%;
                    tabs: tabs;
                    index: index;
                }

                LibraryTreeView {
                    width: 20%;
                    title: @tr("Categories");
                    model: tabs[index].elements;
                }

                Rectangle {
                    width: 1px;
                    background: #555555;
                }

                LibraryTreeView {
                    width: 30%;
                    title: @tr("Elements");
                    model: tabs[index].elements;
                }
            }
        }

        if !tabbed: HorizontalLayout {
            LibraryTreeView {
                horizontal-stretch: 20;
                title: @tr("Categories");
                model: tabs[index].elements;
            }

            Rectangle {
                width: 1px;
                background: #555555;
            }

            LibraryTreeView {
                horizontal-stretch: 30;
                title: @tr("Elements");
                model: tabs[index].elements;
            }

            Rectangle {
                width: 1px;
                background: #555555;
            }

            LibraryMetadataBox {
                horizontal-stretch: 3;
                max-width: 500px;
                tabs: tabs;
                index: index;
            }
        }
    }

    key-pressed(event) => {
        Data.set-current-tab(section-index, index);

        // If the focus is in the command toolbar, make the Escape key moving
        // the focus back to the graphics scene without triggering any action.
        if (event.text == Key.Escape) && (!root.has-focus) {
            root.focus();
            return accept;
        }
        reject
    }

    key-released(event) => {
        Backend.scene-key-event(section-index, event) ? accept : reject
    }
}
