} from "../../api.slint";

component LibraryMetadataBox inherits Rectangle {
    in property <[LibraryTabData]> tabs;
    in property <int> index;

    //preferred-width: 400px;
    background: Palette.background;
    border-bottom-left-radius: 10px;

    GridLayout {
        padding: 10px;
        spacing: 8px;

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Name:");
            }

            LineEdit {
                text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Description:");
            }

            TextEdit {
                height: 100px;
                text: tabs[index].description;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Keywords:");
            }

            LineEdit {
                //text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Author:");
            }

            LineEdit {
                text: tabs[index].author;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Version:");
            }

            LineEdit {
                text: tabs[index].version;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Deprecated:");
            }

            Switch {
                font-size: 10px;
                text: @tr("Check this if the element should no longer be used.");
                checked: tabs[index].deprecated;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("URL:");
            }

            LineEdit {
                text: tabs[index].url;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Dependencies:");
            }

            TextEdit {
                height: 60px;
                //text: tabs[index].name;
            }
        }

        Row {
            Text {
                width: self.preferred-width;
                vertical-alignment: center;
                text: @tr("Manufacturer:");
            }

            LineEdit {
                text: tabs[index].manufacturer;
            }
        }

        Row {
            Rectangle { }
        }
    }
}

component LibraryTreeView inherits VerticalLayout {
    in property <string> title;
    in-out property <[TreeViewItemData]> model;
    in property <int> current-index;

    callback item-selected <=> view.item-selected;

    PanelHeader {
        title: title;
    }

    view := TreeView {
        model: model;
        current-index: current-index;
        show-tree: true;
        supports-expand: false;
    }
}

export component LibraryTab inherits Tab {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[LibraryTabData]> tabs: section.library-tabs;
    property <int> index: section.current-tab-index;
    property <bool> tabbed: self.width < 1024px;

    enabled: true;

    HorizontalLayout {
        VerticalLayout {
            horizontal-stretch: 20;
            spacing: 20px;

            cmpcat-view := LibraryTreeView {
                vertical-stretch: self.model.length;
                title: @tr("Component Categories");
                model: tabs[index].cmp-categories;
                current-index: tabs[index].cmp-categories-index;

                item-selected(idx, item) => {
                    tabs[index].pkg-categories-index = -1;
                    if tabs[index].cmp-categories-index != idx {
                        tabs[index].cmp-categories-index = idx;
                    } else {
                        tabs[index].cmp-categories-index = -1;
                    }
                }
            }

            pkccat-view := LibraryTreeView {
                vertical-stretch: self.model.length;
                title: @tr("Package Categories");
                model: tabs[index].pkg-categories;
                current-index: tabs[index].pkg-categories-index;

                item-selected(idx, item) => {
                    tabs[index].cmp-categories-index = -1;
                    if tabs[index].pkg-categories-index != idx {
                        tabs[index].pkg-categories-index = idx;
                    } else {
                        tabs[index].pkg-categories-index = -1;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #555555;
        }

        TreeView {
            horizontal-stretch: 30;
            model: tabs[index].filtered-elements;
            show-tree: true;
            supports-expand: false;
        }

        Rectangle {
            width: 1px;
            background: #555555;
        }

        LibraryMetadataBox {
            horizontal-stretch: 3;
            max-width: 500px;
            tabs: tabs;
            index: index;
        }
    }

    key-pressed(event) => {
        Data.set-current-tab(section-index, index);

        // If the focus is in the command toolbar, make the Escape key moving
        // the focus back to the graphics scene without triggering any action.
        if (event.text == Key.Escape) && (!root.has-focus) {
            root.focus();
            return accept;
        }
        reject
    }

    key-released(event) => {
        Backend.scene-key-event(section-index, event) ? accept : reject
    }
}
