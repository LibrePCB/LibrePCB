component LibraryMetadataBox inherits GridLayout {
    in property <[LibraryTabData]> tabs;
    in property <int> index;

    padding: 10px;
    spacing: 8px;

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Name:");
        }

        LineEdit {
            text: tabs[index].name;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Description:");
        }

        TextEdit {
            height: 100px;
            text: tabs[index].description;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Keywords:");
        }

        LineEdit {
                //text: tabs[index].name;
            }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Author:");
        }

        LineEdit {
            text: tabs[index].author;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Version:");
        }

        LineEdit {
            text: tabs[index].version;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Deprecated:");
        }

        Switch {
            font-size: 10px;
            text: @tr("Check this if the element should no longer be used.");
            checked: tabs[index].deprecated;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("URL:");
        }

        LineEdit {
            text: tabs[index].url;
        }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Dependencies:");
        }

        TextEdit {
            height: 60px;
                //text: tabs[index].name;
            }
    }

    Row {
        Text {
            width: self.preferred-width;
            vertical-alignment: center;
            text: @tr("Manufacturer:");
        }

        LineEdit {
            text: tabs[index].manufacturer;
        }
    }

    Row {
        Rectangle { }
    }
}

export component LibraryTab inherits Tab {
    in property <int> section-index;
    in-out property <WindowSectionData> section;
    property <[LibraryTabData]> tabs: section.library-tabs;
    property <int> index: section.current-tab-index;
    property <bool> tabbed: self.width < 1024px;

    enabled: true;

    HorizontalLayout {
        TreeView {
            horizontal-stretch: 20;
            model: tabs[index].categories;
            current-index: tabs[index].categories-index;
            show-tree: true;
            supports-expand: false;
            font-size: 12px;
            item-height: 20px;

            item-selected(idx, item) => {
                if idx != tabs[index].categories-index {
                    tabs[index].categories-index = idx;
                    tabs[index].element-index = -1;
                }
            }

            item-triggered(idx, item) => {
                Backend.trigger-tab(section-index, index, TabAction.edit-properties);
                true
            }
        }

        Rectangle {
            width: 1px;
            background: #555555;
        }

        TreeView {
            horizontal-stretch: 30;
            model: tabs[index].filtered-elements;
            current-index: tabs[index].element-index;
            show-tree: true;
            supports-expand: false;
            font-size: 12px;
            item-height: 20px;

            item-selected(idx, item) => {
                tabs[index].element-index = idx;
            }

            item-triggered(idx, item) => {
                Backend.trigger-tab(section-index, index, TabAction.edit-properties);
                true
            }
        }

        Rectangle {
            width: 1px;
            background: #555555;
        }

        LibraryMetadataBox {
            horizontal-stretch: 3;
            max-width: 500px;
            tabs: tabs;
            index: index;
        }
    }

    key-pressed(event) => {
        Data.set-current-tab(section-index, index);

        // If the focus is in the command toolbar, make the Escape key moving
        // the focus back to the graphics scene without triggering any action.
        if (event.text == Key.Escape) && (!root.has-focus) {
            root.focus();
            return accept;
        }
        reject
    }

    key-released(event) => {
        Backend.scene-key-event(section-index, event) ? accept : reject
    }
}
