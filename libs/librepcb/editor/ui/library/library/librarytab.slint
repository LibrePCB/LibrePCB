import { TextEdit } from "std-widgets.slint";
import { Tab } from "../../tab.slint";
import {
    Button,
    ComboBox,
    LineEdit,
    LinkText,
    MessageBox,
    Palette,
    PanelHeader,
    SceneButton,
    Switch,
    ToolButton,
    TreeView,
} from "../../widgets.slint";
import {
    Backend,
    Constants,
    Data,
    DismissableMessageAction,
    EditorCommandSet as Cmd,
    EditorTool,
    LibraryTabData,
    PanelPage,
    TabAction,
    TreeViewItemData,
