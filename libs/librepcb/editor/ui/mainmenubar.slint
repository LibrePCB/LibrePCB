        help-menu-item := MainMenuItem {
            text: @tr("Help");

            clicked => {
                help-menu-popup.show();
            }

            help-menu-popup := MenuPopup {
                x: 0;
                y: parent.height;

                shortcuts-reference-item := MenuItem {
                    cmd: Cmd.keyboard-shortcuts-reference;

                    clicked => {
