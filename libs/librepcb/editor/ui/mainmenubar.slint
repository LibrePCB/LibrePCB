        Rectangle {
            width: 3px;
        }

        Rectangle {
            y: 4px;
            width: 1px;
            height: parent.height - 2 * self.y;
            background: #606060;
        }

        HorizontalLayout {
            padding-top: 5px;
            padding-bottom: 5px;
            padding-left: 8px;
            padding-right: 20px;
            spacing: 5px;

            MenuBarButton {
                enabled: Data.current-tab.can-save;
                icon: @image-url("../../../bootstrap-icons/icons/floppy-fill.svg");
                tooltip: @tr("Save");

                clicked => {
                    Backend.trigger(Action.save);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-export-graphics;
                icon: @image-url("../../../font-awesome/svgs/solid/file-pdf.svg");
                tooltip: @tr("Export PDF");

                clicked => {
                    Backend.trigger(Action.export-pdf);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-export-graphics;
                icon: @image-url("../../../bootstrap-icons/icons/printer-fill.svg");
                tooltip: @tr("Print");

                clicked => {
                    Backend.trigger(Action.print);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-undo;
                icon: @image-url("../../../font-awesome/svgs/solid/rotate-left.svg");
                tooltip: @tr("Undo");

                clicked => {
                    Backend.trigger(Action.undo);
                }
            }

            MenuBarButton {
                enabled: Data.current-tab.can-redo;
                icon: @image-url("../../../font-awesome/svgs/solid/rotate-right.svg");
                tooltip: @tr("Redo");

                clicked => {
                    Backend.trigger(Action.redo);
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;

            if Data.sections[Data.current-section-index].tabs.length > 0: HorizontalLayout {
                property <length> total-space: root.width - sections-start-x;
                property <length> section-width: total-space / Data.sections.length;
                property <length> offset: sections-start-x - parent.x - (self.width / 2);

                x: max(min(section-width * (0.5 + Data.current-section-index) + offset, parent.width - self.width - 10px), 0);
                width: self.preferred-width;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 5px;

                if Data.current-tab.can-cut: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/scissors.svg");
                    tooltip: @tr("Cut");

                    clicked => {
                        Backend.trigger(Action.cut);
                    }
                }

                if Data.current-tab.can-copy: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/regular/copy.svg");
                    tooltip: @tr("Copy");

                    clicked => {
                        Backend.trigger(Action.copy);
                    }
                }

                if Data.current-tab.can-paste: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/paste.svg");
                    tooltip: @tr("Paste");

                    clicked => {
                        Backend.trigger(Action.paste);
                    }
                }

                if Data.current-tab.can-remove: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/trash-can.svg");
                    tooltip: @tr("Delete");

                    clicked => {
                        Backend.trigger(Action.delete);
                    }
                }

                if Data.current-tab.can-rotate: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/rotate-left.svg");
                    tooltip: @tr("Rotate Counter-Clockwise");

                    clicked => {
                        Backend.trigger(Action.rotate-ccw);
                    }
                }

                if Data.current-tab.can-rotate: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/rotate-right.svg");
                    tooltip: @tr("Rotate Clockwise");

                    clicked => {
                        Backend.trigger(Action.rotate-cw);
                    }
                }

                if Data.current-tab.can-mirror: MenuBarButton {
                    icon: @image-url("../../../bootstrap-icons/icons/symmetry-horizontal.svg");
                    tooltip: @tr("Mirror Horizontally");

                    clicked => {
                        Backend.trigger(Action.mirror-horizontally);
                    }
                }

                if Data.current-tab.can-mirror: MenuBarButton {
                    icon: @image-url("../../../bootstrap-icons/icons/symmetry-vertical.svg");
                    tooltip: @tr("Mirror Vertically");

                    clicked => {
                        Backend.trigger(Action.mirror-vertically);
                    }
                }

                if Data.current-tab.can-move-align: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/up-down-left-right.svg");
                    tooltip: @tr("Move/Align");

                    clicked => {
                        Backend.trigger(Action.move-align);
                    }
                }

                if Data.current-tab.can-snap-to-grid: MenuBarButton {
                    icon: @image-url("../../../../img/grid-dots.svg");
                    tooltip: @tr("Snap to Grid");

                    clicked => {
                        Backend.trigger(Action.snap-to-grid);
                    }
                }

                if Data.current-tab.can-reset-texts: MenuBarButton {
                    icon: @image-url("../../../bootstrap-icons/icons/bootstrap-reboot.svg");
                    tooltip: @tr("Reset all Texts");

                    clicked => {
                        Backend.trigger(Action.reset-texts);
                    }
                }

                if Data.current-tab.can-lock-placement: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/lock-open.svg");
                    tooltip: @tr("Lock/Unlock Placement");

                    clicked => {
                        Backend.trigger(Action.lock-unlock-placement);
                    }
                }

                if Data.current-tab.can-edit-properties: MenuBarButton {
                    icon: @image-url("../../../font-awesome/svgs/solid/pen-to-square.svg");
                    tooltip: @tr("Properties");

                    clicked => {
                        Backend.trigger(Action.edit-properties);
                    }
                }
            }
        }

        le-search := LineEdit {
            y: 2px;
            height: parent.height - 2 * self.y;
            horizontal-stretch: 0;
            font-size: 11px;
            placeholder-text: @tr("Quick Find (Ctrl+F)");

            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    self.clear-focus();
                    return accept;
                }
                return reject;
            }
        }
    }
}
