import { MenuPopup, MenuItem, MenuSeparator, ToolTip, LineEdit, Palette } from "widgets.slint";
import {
    Action,
    Backend,
    Constants,
    Data,
    EditorCommandSet as Cmd,
    PanelPage,
    TabType
} from "api.slint";

component MainMenuItem inherits Rectangle {
    in property <string> text;

    callback clicked <=> ta.clicked;

    width: txt.preferred-width + 10px;
    background: ta.has-hover ? #505050 : #252525;

    // Accessibility
    accessible-role: button;
    accessible-label: text;
    accessible-action-default => {
        ta.clicked();
    }

    txt := Text {
        x: 5px;
        font-size: 15px;
        text: text;
    }

    ta := TouchArea { }
}

component MenuBarButton inherits TouchArea {
    in property <image> icon;
    in property <string> tooltip;

    width: self.height;

    // Accessibility
    accessible-role: button;
    accessible-enabled: self.enabled;
    accessible-label: tooltip;
    accessible-action-default => {
        self.clicked();
    }

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.pressed ? 90% : 100%;
        height: self.width;
        image-fit: contain;
        colorize: (!root.enabled) ? #606060 : (root.has-hover ? white : Palette.foreground);
        source: icon;
        accessible-role: none;
    }

    if self.has-hover && (!self.pressed): ToolTip {
        x: (parent.width - self.width) / 2;
        y: parent.height + 5px;
        text: tooltip;
    }
}

export component MainMenuBar inherits Rectangle {
